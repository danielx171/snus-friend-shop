# Frontend (public-ish)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=
VITE_PREVIEW_MODE=false   # set to 'true' in Vercel to disable checkout before go-live

# Anything sensitive should NOT go here.
# Keep secrets ONLY in Supabase Edge Function secrets:
# - SUPABASE_SERVICE_ROLE_KEY
# - NYEHANDEL_API_URL
# - NYEHANDEL_API_TOKEN
# - NYEHANDEL_X_IDENTIFIER
# - NYEHANDEL_WEBHOOK_SECRET
# - DELIVERY_WEBHOOK_SECRET          # shared secret for nyehandel-delivery-callback auth
# - ALLOWED_ORIGIN                   # CORS origin for create-nyehandel-checkout (e.g. https://nordicpouch.com)
# - SYNC_CRON_SECRET                 # auth for pg_cron auto-sync invocations
# - INTERNAL_FUNCTIONS_SECRET
# - RETRY_FAILED_ORDERS_SECRET
# - OPS_ALERTS_CRON_SECRET
