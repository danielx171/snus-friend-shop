# Frontend (public-ish)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=
VITE_PREVIEW_MODE=false   # set to 'true' in Vercel to disable checkout before go-live

# Anything sensitive should NOT go here.
# Keep secrets ONLY in Supabase Edge Function secrets (Dashboard → Settings → Vault):
# - SUPABASE_SERVICE_ROLE_KEY        # service role for all edge functions
# - SUPABASE_ANON_KEY                # anon key for verify-admin, ops-users, ops-set-role, nyehandel-proxy
# - NYEHANDEL_API_URL                # Nyehandel API base URL (e.g. https://api.nyehandel.se)
# - NYEHANDEL_API_TOKEN              # Nyehandel Bearer token
# - NYEHANDEL_X_IDENTIFIER           # Nyehandel account identifier header
# - NYEHANDEL_WEBHOOK_SECRET         # x-api-key for nyehandel-webhook auth
# - DELIVERY_WEBHOOK_SECRET          # shared secret for nyehandel-delivery-callback auth (REQUIRED — without it all delivery callbacks are accepted)
# - ALLOWED_ORIGIN                   # CORS origin for create-nyehandel-checkout (REQUIRED — without it defaults to * in prod)
# - SYNC_CRON_SECRET                 # auth for pg_cron auto-sync invocations
# - INTERNAL_FUNCTIONS_SECRET        # x-internal-function-secret for push-order-to-nyehandel
# - RETRY_FAILED_ORDERS_SECRET       # x-cron-secret for retry-failed-nyehandel-orders
# - OPS_ALERTS_CRON_SECRET           # x-cron-secret for ops-b2b-queues
#
# Also seed sync_config table after migration:
#   INSERT INTO sync_config (key, value) VALUES
#     ('supabase_project_url', 'https://<ref>.supabase.co'),
#     ('sync_cron_secret', '<same-as-SYNC_CRON_SECRET>');
