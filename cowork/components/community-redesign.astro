---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import QuestBoardIsland from '@/components/react/QuestBoardIsland';
import LeaderboardIsland from '@/components/react/LeaderboardIsland';
import AchievementGridIsland from '@/components/react/AchievementGridIsland';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Community — Connect, Compete & Earn | ${tenant.name}`}
  description={`Join the ${tenant.name} community. Share reviews, climb the leaderboard, complete quests, unlock achievements, and earn exclusive rewards through our gamified loyalty system.`}
>
  <section class="bg-background text-foreground">
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-gradient-to-b from-primary/5 via-background to-background border-b border-border/30">
      <div class="max-w-5xl mx-auto px-4 py-16 sm:py-20 md:py-24">
        <Breadcrumb items={[{ label: 'Community' }]} />

        <div class="text-center">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4">
            The SnusFriend Community
          </h1>
          <p class="text-lg sm:text-xl text-muted-foreground max-w-3xl mx-auto mb-8">
            Connect with thousands of pouch enthusiasts. Share reviews, earn points, complete quests, and unlock exclusive rewards as you climb the ranks.
          </p>

          <!-- Key Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6 max-w-2xl mx-auto mb-10">
            <div class="rounded-lg bg-card/40 backdrop-blur-sm border border-border/30 p-4 sm:p-6">
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">2,847</div>
              <p class="text-xs sm:text-sm text-muted-foreground">Active Members</p>
            </div>
            <div class="rounded-lg bg-card/40 backdrop-blur-sm border border-border/30 p-4 sm:p-6">
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">15.3K</div>
              <p class="text-xs sm:text-sm text-muted-foreground">Reviews Posted</p>
            </div>
            <div class="rounded-lg bg-card/40 backdrop-blur-sm border border-border/30 p-4 sm:p-6">
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">94.2M</div>
              <p class="text-xs sm:text-sm text-muted-foreground">Points Earned</p>
            </div>
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/login?redirect=/community"
              class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm sm:text-base font-semibold text-primary-foreground hover:bg-primary/90 transition"
            >
              Join the Community
            </a>
            <a
              href="/products"
              class="inline-flex items-center justify-center rounded-lg border border-primary/30 bg-primary/5 px-6 py-3 text-sm sm:text-base font-semibold text-primary hover:bg-primary/10 transition"
            >
              Browse Products
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-5xl mx-auto px-4 py-12 sm:py-16">
      <!-- Leaderboard Section -->
      <div class="mb-12 sm:mb-16">
        <div class="mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-2">The Rankings</h2>
          <p class="text-muted-foreground">
            Earn points with every review, purchase, and quest completion. Climb the global leaderboard and unlock exclusive tier-based rewards.
          </p>
        </div>
        <LeaderboardIsland client:visible />
      </div>

      <!-- Active Quests Section -->
      <div class="mb-12 sm:mb-16">
        <div class="mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-2">Active Quests</h2>
          <p class="text-muted-foreground">
            Complete daily and weekly challenges to earn bonus points, unlock achievements, and progress through the quest tiers.
          </p>
        </div>
        <QuestBoardIsland client:idle />
      </div>

      <!-- Achievements Section -->
      <div class="mb-12 sm:mb-16">
        <div class="mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-2">Achievements Showcase</h2>
          <p class="text-muted-foreground">
            Unlock rare achievements by completing special challenges, reaching milestones, and exploring hidden quests.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <AchievementGridIsland client:visible />
        </div>
      </div>

      <!-- How It Works Section -->
      <div class="mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">How The Tier System Works</h2>

        <!-- Tier Progression Visual -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
          <!-- Bronze -->
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 text-center">
            <div class="flex justify-center mb-4">
              <span class="text-4xl">🥉</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Bronze</h3>
            <div class="text-2xl font-bold text-amber-700 mb-2">0–999</div>
            <p class="text-sm text-muted-foreground mb-4">
              Welcome to the community. Earn your first points.
            </p>
            <ul class="text-xs text-muted-foreground space-y-2 text-left">
              <li>✓ 5% points bonus</li>
              <li>✓ Monthly spin</li>
              <li>✓ Basic badge</li>
            </ul>
          </div>

          <!-- Silver -->
          <div class="rounded-xl border border-primary/30 bg-card/60 backdrop-blur-sm p-6 text-center">
            <div class="flex justify-center mb-4">
              <span class="text-4xl">🥈</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Silver</h3>
            <div class="text-2xl font-bold text-slate-400 mb-2">1,000–4,999</div>
            <p class="text-sm text-muted-foreground mb-4">
              Becoming a respected community member.
            </p>
            <ul class="text-xs text-muted-foreground space-y-2 text-left">
              <li>✓ 10% points bonus</li>
              <li>✓ Bi-weekly spin</li>
              <li>✓ Silver badge</li>
            </ul>
          </div>

          <!-- Gold -->
          <div class="rounded-xl border border-primary/30 bg-card/60 backdrop-blur-sm p-6 text-center">
            <div class="flex justify-center mb-4">
              <span class="text-4xl">🥇</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Gold</h3>
            <div class="text-2xl font-bold text-yellow-600 mb-2">5,000–14,999</div>
            <p class="text-sm text-muted-foreground mb-4">
              Elite member with exclusive perks.
            </p>
            <ul class="text-xs text-muted-foreground space-y-2 text-left">
              <li>✓ 15% points bonus</li>
              <li>✓ Weekly spin</li>
              <li>✓ Gold badge + icon</li>
            </ul>
          </div>

          <!-- Diamond -->
          <div class="rounded-xl border border-primary/30 bg-card/60 backdrop-blur-sm p-6 text-center">
            <div class="flex justify-center mb-4">
              <span class="text-4xl">💎</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Diamond</h3>
            <div class="text-2xl font-bold text-cyan-400 mb-2">15,000+</div>
            <p class="text-sm text-muted-foreground mb-4">
              Legendary status in the community.
            </p>
            <ul class="text-xs text-muted-foreground space-y-2 text-left">
              <li>✓ 20% points bonus</li>
              <li>✓ Unlimited spins</li>
              <li>✓ Diamond badge + custom</li>
            </ul>
          </div>
        </div>

        <!-- How to Earn Section -->
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 sm:p-8">
          <h3 class="text-xl font-bold mb-6">Ways to Earn Points</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex gap-4">
              <span class="flex-shrink-0 text-2xl">⭐</span>
              <div>
                <h4 class="font-semibold mb-1">Write a Review</h4>
                <p class="text-sm text-muted-foreground">Post a product review and earn up to 50 points.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 text-2xl">🛍️</span>
              <div>
                <h4 class="font-semibold mb-1">Make a Purchase</h4>
                <p class="text-sm text-muted-foreground">Earn 1 point per £1 spent on products.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 text-2xl">✅</span>
              <div>
                <h4 class="font-semibold mb-1">Complete Quests</h4>
                <p class="text-sm text-muted-foreground">Daily and weekly quests award 10–100 points.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 text-2xl">🎯</span>
              <div>
                <h4 class="font-semibold mb-1">Earn Achievements</h4>
                <p class="text-sm text-muted-foreground">Unlock special achievements for 5–25 bonus points.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Reviews Section -->
      <div class="mb-12 sm:mb-16">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-1">Community Reviews</h2>
            <p class="text-muted-foreground">
              Share your honest opinion and help others discover their favourite pouches.
            </p>
          </div>
        </div>

        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            <!-- Review 1 -->
            <div class="rounded-lg bg-muted/40 p-4 sm:p-6 hover:bg-muted/60 transition">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-semibold text-foreground">VELO Freeze Max</p>
                  <p class="text-xs text-muted-foreground">5 days ago</p>
                </div>
                <div class="flex gap-0.5">
                  {[1, 2, 3, 4, 5].map(() => (
                    <span class="text-primary text-sm">★</span>
                  ))}
                </div>
              </div>
              <p class="text-sm text-foreground mb-3">
                "Outstanding strength and flavour. This is my go-to pouch. Highly recommend to anyone looking for an intense freeze hit."
              </p>
              <p class="text-xs text-muted-foreground">
                By <span class="font-medium">Sarah K.</span> • 347 helpful votes
              </p>
            </div>

            <!-- Review 2 -->
            <div class="rounded-lg bg-muted/40 p-4 sm:p-6 hover:bg-muted/60 transition">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-semibold text-foreground">ZYN Spearmint</p>
                  <p class="text-xs text-muted-foreground">1 week ago</p>
                </div>
                <div class="flex gap-0.5">
                  {[1, 2, 3, 4].map(() => (
                    <span class="text-primary text-sm">★</span>
                  ))}
                  <span class="text-muted/30 text-sm">★</span>
                </div>
              </div>
              <p class="text-sm text-foreground mb-3">
                "Great flavour and consistent quality. Perfect for daytime use. Would love to see a stronger option in the range."
              </p>
              <p class="text-xs text-muted-foreground">
                By <span class="font-medium">James T.</span> • 214 helpful votes
              </p>
            </div>
          </div>

          <div class="flex gap-3">
            <a
              href="/products"
              class="flex-1 rounded-lg border border-primary/30 bg-primary/5 px-4 py-2 text-sm font-semibold text-primary hover:bg-primary/10 transition text-center"
            >
              View All Reviews
            </a>
            <a
              href="/products"
              class="flex-1 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition text-center"
            >
              Write a Review
            </a>
          </div>
        </div>
      </div>

      <!-- Community Guidelines -->
      <div class="mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-6">Community Guidelines</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <div class="flex gap-4 mb-4">
              <span class="text-2xl">✨</span>
              <div>
                <h3 class="font-semibold mb-2">Be Respectful</h3>
                <p class="text-sm text-muted-foreground">
                  Treat other community members with kindness and dignity, regardless of differing opinions or backgrounds.
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <div class="flex gap-4 mb-4">
              <span class="text-2xl">✓</span>
              <div>
                <h3 class="font-semibold mb-2">Be Honest</h3>
                <p class="text-sm text-muted-foreground">
                  Share genuine experiences and authentic opinions. Reviews should be based on real use, not marketing hype.
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <div class="flex gap-4 mb-4">
              <span class="text-2xl">🙌</span>
              <div>
                <h3 class="font-semibold mb-2">Be Helpful</h3>
                <p class="text-sm text-muted-foreground">
                  Provide constructive feedback. Compare products, explain your preferences, and help others make informed choices.
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <div class="flex gap-4 mb-4">
              <span class="text-2xl">⚠️</span>
              <div>
                <h3 class="font-semibold mb-2">No Spam or Abuse</h3>
                <p class="text-sm text-muted-foreground">
                  Avoid promotional spam, offensive language, or harassing behaviour. Keep discussions focused on nicotine pouches.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Footer -->
      <div class="rounded-xl border border-primary/30 bg-gradient-to-r from-primary/5 to-primary/10 p-8 sm:p-10 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold mb-3">Ready to Join?</h2>
        <p class="text-muted-foreground mb-6 max-w-2xl mx-auto">
          Create your free SnusFriend account to start earning points, unlocking achievements, and competing on the global leaderboard.
        </p>
        <a
          href="/login?redirect=/community"
          class="inline-flex items-center justify-center rounded-lg bg-primary px-8 py-3 text-base font-semibold text-primary-foreground hover:bg-primary/90 transition"
        >
          Get Started Now
        </a>
      </div>
    </div>
  </section>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "The SnusFriend Community",
      "description": "Join thousands of nicotine pouch enthusiasts. Share reviews, earn points, complete quests, and unlock exclusive rewards.",
      "url": "https://snusfriends.com/community",
      "publisher": {
        "@type": "Organization",
        "name": "SnusFriend",
        "logo": {
          "@type": "ImageObject",
          "url": "https://snusfriends.com/logo.svg"
        }
      },
      "isPartOf": {
        "@type": "WebSite",
        "name": "SnusFriend",
        "url": "https://snusfriends.com"
      },
      "mainEntity": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://snusfriends.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Community",
            "item": "https://snusfriends.com/community"
          }
        ]
      }
    }
  </script>
</Shop>
