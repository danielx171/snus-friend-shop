---
import { tenant } from '@/config/tenant';
---

{tenant.features.ageGate && (
  <div id="age-gate" class="fixed inset-0 z-[200] flex items-center justify-center bg-background">
    <div class="mx-4 max-w-md rounded-lg border border-border bg-card p-5 sm:p-8 text-center shadow-xl">
      <h2 class="text-2xl font-bold text-foreground">Age Verification</h2>
      <p class="mt-3 text-sm text-muted-foreground">
        You must be 18 years or older to access this site. Nicotine products are intended for adult use only.
      </p>
      <div class="mt-6 flex flex-col gap-3">
        <button
          id="age-gate-confirm"
          class="rounded-md bg-primary px-6 py-4 min-h-[48px] w-full text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          I am 18 or older
        </button>
        <button
          id="age-gate-deny"
          class="rounded-md border border-border px-6 py-4 min-h-[48px] w-full text-base font-medium text-muted-foreground transition-colors hover:bg-accent"
        >
          I am under 18
        </button>
      </div>
      <p class="mt-4 text-xs text-muted-foreground">
        By continuing, you accept our use of essential cookies.
        <a href="/cookies" class="underline hover:text-foreground">Cookie Policy</a>
      </p>
    </div>
  </div>
)}

<script is:inline define:vars={{ storageKey: tenant.storage.ageVerifiedKey, enabled: tenant.features.ageGate }}>
  (function() {
    if (!enabled) return;

    function init() {
      var gate = document.getElementById('age-gate');
      if (!gate) return;

      var verified = false;
      try { verified = localStorage.getItem(storageKey) === 'true'; } catch(e) {}

      if (verified) {
        gate.style.display = 'none';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        return;
      }

      // Lock scrolling — both html+body for iOS Safari compatibility
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';

      function confirmAge() {
        try { localStorage.setItem(storageKey, 'true'); } catch(e) {}
        gate.style.display = 'none';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        window.dispatchEvent(new Event('age-verified'));
      }

      function denyAge() {
        window.location.href = 'https://google.com';
      }

      // Use onclick instead of addEventListener to avoid stale duplicates
      // after Astro View Transitions replace the DOM
      var confirmBtn = document.getElementById('age-gate-confirm');
      var denyBtn = document.getElementById('age-gate-deny');

      if (confirmBtn) {
        confirmBtn.onclick = confirmAge;
      }

      if (denyBtn) {
        denyBtn.onclick = denyAge;
      }
    }

    // Run on initial load
    if (document.getElementById('age-gate')) {
      init();
    } else {
      document.addEventListener('DOMContentLoaded', init);
    }

    // Re-run after Astro View Transitions replace the DOM
    document.addEventListener('astro:page-load', init);
  })();
</script>
