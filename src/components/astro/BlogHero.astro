---
/**
 * Blog article hero banner with category-colored gradient.
 * Replaces the plain white header area on blog posts.
 */
interface Props {
  category: string;
  title: string;
  description: string;
  date: string;
  readTime: string;
}

const { category, title, description, date, readTime } = Astro.props;

const categoryColors: Record<string, string> = {
  'Brand Spotlight': '#2E7D32',
  'Comparison': '#1565C0',
  'Buying Guide': '#E65100',
  'Guide': '#1a2e1a',
  'Ranking': '#6A1B9A',
  'Flavour Guide': '#00838F',
  'FAQ': '#37474F',
};

const color = categoryColors[category] ?? '#1a2e1a';
---

<div class="rounded-2xl overflow-hidden mb-8" style={`background: linear-gradient(135deg, ${color}dd, ${color}88);`}>
  <div class="px-6 py-10 sm:px-8 sm:py-14">
    <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur mb-4">
      {category}
    </span>
    <h1 class="text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl" style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;">
      {title}
    </h1>
    <p class="mt-3 text-base text-white/75 leading-relaxed max-w-2xl">
      {description}
    </p>
    <div class="mt-4 flex items-center gap-3 text-sm text-white/60">
      <span>By SnusFriends Editorial</span>
      <span>&middot;</span>
      <time>{date}</time>
      <span>&middot;</span>
      <span>{readTime}</span>
    </div>
  </div>
</div>
