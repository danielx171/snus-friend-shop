---
interface Props {
  variant?: 'full' | 'mark';
  color?: 'dark' | 'light';
  class?: string;
}

const { variant = 'full', color = 'dark', class: className = '' } = Astro.props;

const primaryColor = color === 'dark' ? '#1a2e1a' : '#faf8f5';
const accentColor = color === 'dark' ? '#4a6741' : '#a8c0a0';
---

{variant === 'full' ? (
  <svg viewBox="0 0 160 32" xmlns="http://www.w3.org/2000/svg" class={`h-8 w-auto ${className}`} aria-label="SnusFriend" role="img">
    <!-- Nordic diamond/leaf mark -->
    <g transform="translate(4, 6)">
      <path d="M 8 0 L 16 8 L 8 16 L 0 8 Z" fill="none" stroke={primaryColor} stroke-width="1.2"/>
      <path d="M 8 5 Q 6 8 8 12 Q 10 8 8 5 Z" fill={accentColor}/>
    </g>
    <!-- Wordmark -->
    <text x="28" y="22" font-family="'Space Grotesk', 'Inter', system-ui, sans-serif" font-size="19" font-weight="700" letter-spacing="-0.3" fill={primaryColor}>
      SnusFriend
    </text>
  </svg>
) : (
  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class={`h-8 w-8 ${className}`} aria-label="SnusFriend" role="img">
    <circle cx="16" cy="16" r="15" fill={color === 'dark' ? '#faf8f5' : '#1a2e1a'} stroke={primaryColor} stroke-width="1"/>
    <g transform="translate(10, 8)">
      <path d="M 6 0 L 12 6 L 6 12 L 0 6 Z" fill="none" stroke={primaryColor} stroke-width="1.2"/>
      <path d="M 6 3.5 Q 4.5 6 6 9 Q 7.5 6 6 3.5 Z" fill={accentColor}/>
    </g>
  </svg>
)}
