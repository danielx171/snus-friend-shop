---
export const prerender = false;

import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { actions } from 'astro:actions';
import { tenant } from '@/config/tenant';

const result = Astro.getActionResult(actions.auth.forgotPassword);

const errorMessage = result?.error?.message;
const submitted = result?.data?.success;
---

<Shop
  title={`Forgot Password | ${tenant.name}`}
  description="Reset your password to regain access to your account."
  noindex={true}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Forgot Password' }]} />

      <div class="max-w-md mx-auto">
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8">
          <h1 class="text-3xl font-bold tracking-tight mb-2 text-center">Reset Password</h1>
          <p class="text-muted-foreground text-center mb-8">
            Enter your email address and we'll send you a link to reset your password.
          </p>

          {errorMessage && (
            <div role="alert" aria-live="assertive" class="mb-6 rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-center">
              <p class="text-sm text-destructive font-medium">{errorMessage}</p>
            </div>
          )}

          {submitted ? (
            <div class="rounded-lg border border-primary/30 bg-primary/5 p-4 text-center">
              <p class="text-sm text-foreground font-medium mb-1">Check your inbox</p>
              <p class="text-sm text-muted-foreground">
                If an account exists with that email, we've sent a password reset link.
              </p>
            </div>
          ) : (
            <form method="POST" action={actions.auth.forgotPassword} class="space-y-5">
              <div>
                <label for="email" class="block text-sm font-medium text-foreground mb-1.5">
                  Email address
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@example.com"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                />
              </div>

              <button
                type="submit"
                class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition focus:outline-none focus:ring-2 focus:ring-primary/50"
              >
                Send Reset Link
              </button>
            </form>
          )}

          <p class="mt-6 text-center text-sm text-muted-foreground">
            Remember your password?
            <a href="/login" class="text-primary font-medium hover:underline">
              Back to login
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Shop>
