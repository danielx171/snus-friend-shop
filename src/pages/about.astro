---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const allBrands = await getCollection('brands');
const brandSlugsWithProducts = new Set(allProducts.map((p) => p.data.brandSlug));
const activeBrandCount = allBrands.filter((b) => brandSlugsWithProducts.has(b.id)).length || 57;
---

<Shop
  title={`About Us — Europe's Nicotine Pouch Shop | ${tenant.name}`}
  description={`Learn about ${tenant.name} — Europe's premium nicotine pouch shop with ${allProducts.length}+ cans from ${activeBrandCount} brands. Fast EU-wide delivery and unbeatable prices.`}
>
  <!-- Hero banner -->
  <section style={`background: hsl(var(--hero-bg)); color: hsl(var(--hero-text));`}>
    <div class="max-w-4xl mx-auto px-4 py-16 sm:py-20 text-center">
      <Breadcrumb items={[{ label: 'About Us' }]} />
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl mt-4" style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;">
        About {tenant.name}
      </h1>
      <p class="mt-4 text-lg max-w-2xl mx-auto leading-relaxed" style={`color: hsl(var(--hero-muted));`}>
        We started {tenant.name} with a simple belief: buying nicotine pouches online should
        be easy, affordable, and enjoyable.
      </p>
    </div>
  </section>

  <!-- Stats row -->
  <section class="border-b border-border bg-card/50">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground">{allProducts.length}+</div>
          <div class="text-sm text-muted-foreground">Cans</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground">{activeBrandCount}</div>
          <div class="text-sm text-muted-foreground">Brands</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground">43</div>
          <div class="text-sm text-muted-foreground">Expert Guides</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground">EU</div>
          <div class="text-sm text-muted-foreground">Free Shipping</div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">

      <!-- Mission -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-8">
        <h2 class="text-2xl font-semibold mb-3">Our Mission</h2>
        <p class="text-muted-foreground leading-relaxed">
          To be the most trusted nicotine pouch shop in Europe. We curate the widest
          selection — over <strong class="text-foreground">{allProducts.length} cans</strong> from
          <strong class="text-foreground">{activeBrandCount} brands</strong> — so you always find the
          right strength, flavour, and format for you.
        </p>
      </div>

      <!-- Values -->
      <div class="grid gap-6 sm:grid-cols-2 mb-10">
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h3 class="text-lg font-semibold mb-2">Honest Pricing</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            No hidden fees. The price you see is the price you pay. Orders over
            &euro;{tenant.freeShippingThreshold} ship free across the EU.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h3 class="text-lg font-semibold mb-2">Fast Delivery</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            We dispatch orders the same or next business day from our EU warehouse.
            Most deliveries arrive within 2-5 business days.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h3 class="text-lg font-semibold mb-2">Real Selection</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            From bestsellers like VELO and ZYN to niche Swedish brands, we stock what
            matters. New arrivals are added every week.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h3 class="text-lg font-semibold mb-2">Community First</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Our loyalty programme, product reviews, and community hub let you share
            recommendations and earn rewards along the way.
          </p>
        </div>
      </div>

      <!-- Who we are -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-8">
        <h2 class="text-2xl font-semibold mb-3">Who We Are</h2>
        <p class="text-muted-foreground leading-relaxed mb-4">
          {tenant.name} is an EU-based e-commerce company specialising exclusively in
          tobacco-free nicotine pouches. We work directly with manufacturers and authorised
          distributors to guarantee product authenticity and freshness.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Our team is small and focused: every support ticket, every product listing, and
          every quality check gets personal attention. When you email us, a real person
          replies — usually within a few hours.
        </p>
      </div>

      <!-- Responsible use -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-10">
        <h2 class="text-2xl font-semibold mb-3">Responsible Use</h2>
        <p class="text-muted-foreground leading-relaxed">
          Nicotine pouches are intended for adults only. We verify age at checkout and
          comply with all applicable EU regulations. If you have questions about nicotine
          strength or choosing the right product, our support team is happy to help.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/nicotine-pouches" class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-base font-semibold text-primary-foreground transition hover:bg-primary/90">
          Start Shopping
        </a>
        <a href="/blog" class="inline-flex h-12 items-center justify-center rounded-lg border border-border px-8 text-base font-semibold text-foreground transition hover:bg-muted">
          Read Our Guides
        </a>
      </div>
    </div>
  </section>
</Shop>
