const description = 'Overwhelmed by pouch options? Here\'s exactly which low-strength brands to try first, what strength to start with, and what to expect in your first week.';
---

<Shop
  title={`${title} | ${tenant.name}`}
  description={description}
  ogType="article"
>
  <article class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[
        { label: 'Blog', href: '/blog' },
        { label: 'Beginner Guide 2026' },
      ]} />

      <header class="mb-10">
        <p class="mb-3 text-sm font-medium uppercase tracking-widest text-primary">Buying Guide</p>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{title}</h1>
        <p class="mt-4 text-lg text-muted-foreground leading-relaxed">{description}</p>
