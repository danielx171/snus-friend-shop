---
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';

const articles = [
  {
    title: 'What Are Nicotine Pouches?',
    excerpt: 'A beginner-friendly guide to tobacco-free nicotine pouches — how they work, how to use them, and why millions of Europeans are making the switch.',
    slug: 'what-are-nicotine-pouches',
  },
  {
    title: 'How to Choose Your Strength',
    excerpt: 'From light (4 mg) to extra strong (20 mg+), picking the right nicotine strength matters. Here\'s a simple framework to find your sweet spot.',
    slug: 'how-to-choose-your-strength',
  },
  {
    title: 'Top 10 Mint Flavours',
    excerpt: 'We ranked the best mint and menthol nicotine pouches across 91 brands. Cool, icy, or spearmint — there\'s a mint for everyone.',
    slug: 'top-10-mint-flavours',
  },
];
---

<Shop
  title={`Blog | ${tenant.name}`}
  description={`Guides, reviews, and news about nicotine pouches from ${tenant.name}. Learn about strengths, flavours, brands, and more.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Blog' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-3">Blog</h1>
      <p class="text-lg text-muted-foreground mb-10">
        Guides, reviews, and tips to help you find the perfect pouch.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <article class="group relative rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 flex flex-col">
            <span class="absolute top-4 right-4 inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
              Coming Soon
            </span>
            <h2 class="text-lg font-semibold mb-2 pr-20">{article.title}</h2>
            <p class="text-sm text-muted-foreground leading-relaxed flex-1">
              {article.excerpt}
            </p>
            <div class="mt-4 pt-4 border-t border-border">
              <span class="text-xs text-muted-foreground/60">Article coming soon</span>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8 text-center">
        <h2 class="text-xl font-semibold mb-2">More articles on the way</h2>
        <p class="text-muted-foreground text-sm max-w-md mx-auto">
          We're working on in-depth guides, brand spotlights, and flavour deep-dives.
          Check back soon or follow us on social media for updates.
        </p>
      </div>
    </div>
  </section>
</Shop>
