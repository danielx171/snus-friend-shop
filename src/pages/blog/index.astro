---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';

const articles = [
  {
    title: 'What Are Nicotine Pouches? A Complete Guide',
    excerpt: 'A beginner-friendly guide to tobacco-free nicotine pouches — how they work, how to use them, and why millions of Europeans are making the switch.',
    slug: 'what-are-nicotine-pouches',
    tag: 'Guide',
  },
  {
    title: 'How to Choose the Right Nicotine Strength',
    excerpt: 'From light (2 mg) to super strong (20 mg+), picking the right strength matters. Here is a practical framework based on your experience level.',
    slug: 'how-to-choose-your-strength',
    tag: 'Guide',
  },
  {
    title: 'Top 10 Mint Nicotine Pouches in 2026',
    excerpt: 'We ranked the best mint and menthol nicotine pouches from 91+ brands. From icy peppermint to smooth spearmint — find your perfect mint.',
    slug: 'top-10-mint-flavours',
    tag: 'Ranking',
  },
];
---

<Shop
  title={`Blog | ${tenant.name}`}
  description={`Guides, reviews, and news about nicotine pouches from ${tenant.name}. Learn about strengths, flavours, brands, and more.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Blog' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-3">Blog</h1>
      <p class="text-lg text-muted-foreground mb-10">
        Guides, reviews, and tips to help you find the perfect pouch.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <a href={`/blog/${article.slug}`} class="group rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 flex flex-col transition hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5">
            <span class="inline-flex self-start items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary mb-3">
              {article.tag}
            </span>
            <h2 class="text-lg font-semibold mb-2 text-foreground group-hover:text-primary transition-colors">{article.title}</h2>
            <p class="text-sm text-muted-foreground leading-relaxed flex-1">
              {article.excerpt}
            </p>
            <div class="mt-4 pt-4 border-t border-border">
              <span class="text-sm font-medium text-primary">Read article &rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8 text-center">
        <h2 class="text-xl font-semibold mb-2">More articles coming soon</h2>
        <p class="text-muted-foreground text-sm max-w-md mx-auto">
          We are working on brand spotlights, flavour deep-dives, and comparison guides.
          Check back soon for new content.
        </p>
      </div>
    </div>
  </section>
</Shop>
