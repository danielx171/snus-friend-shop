          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <a href="/products/strength/mild" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Mild (2-4 mg)</a>
            <a href="/products/strength/regular" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Regular (4-8 mg)</a>
            <a href="/products/strength/strong" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Strong (8-12 mg)</a>
          </div>
        </div>
        <div>
