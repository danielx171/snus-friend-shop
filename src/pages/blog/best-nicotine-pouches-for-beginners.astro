          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <a href="/products/flavor/mint" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Mint</a>
            <a href="/products/flavor/citrus" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Citrus</a>
            <a href="/products/flavor/berry" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Berry</a>
            <a href="/products/flavor/coffee" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Coffee</a>
            <a href="/products/flavor/exotic" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Exotic</a>
            <a href="/products/flavor/tobacco" class="rounded-lg border border-border bg-card px-4 py-3 text-center text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">Tobacco</a>
          </div>
        </div>
      </div>

    </div>
  </article>

