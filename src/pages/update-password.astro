---
export const prerender = false;

import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { actions } from 'astro:actions';
import { tenant } from '@/config/tenant';

const result = Astro.getActionResult(actions.auth.updatePassword);

const errorMessage = result?.error?.message;
const success = result?.data?.success;
---

<Shop
  title={`Update Password | ${tenant.name}`}
  description="Set a new password for your account."
  noindex={true}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Update Password' }]} />

      <div class="max-w-md mx-auto">
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8">
          <h1 class="text-3xl font-bold tracking-tight mb-2 text-center">Update Password</h1>
          <p class="text-muted-foreground text-center mb-8">
            Choose a new password for your account.
          </p>

          <noscript>
            <div class="mb-6 rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-center">
              <p class="text-sm text-destructive font-medium">
                JavaScript is required to verify your password reset token. Please enable JavaScript and reload this page.
              </p>
            </div>
          </noscript>

          <p id="token-status" class="hidden text-sm mb-4"></p>

          {errorMessage && (
            <div class="mb-6 rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-center">
              <p class="text-sm text-destructive font-medium">{errorMessage}</p>
            </div>
          )}

          {success ? (
            <div class="rounded-lg border border-primary/30 bg-primary/5 p-4 text-center">
              <p class="text-sm text-foreground font-medium mb-1">Password updated!</p>
              <p class="text-sm text-muted-foreground">Redirecting to login...</p>
            </div>
          ) : (
            <form method="POST" action={actions.auth.updatePassword} class="space-y-5">
              <div>
                <label for="password" class="block text-sm font-medium text-foreground mb-1.5">
                  New password
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  autocomplete="new-password"
                  minlength="8"
                  placeholder="At least 8 characters"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                />
              </div>

              <div>
                <label for="confirmPassword" class="block text-sm font-medium text-foreground mb-1.5">
                  Confirm new password
                </label>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                  autocomplete="new-password"
                  minlength="8"
                  placeholder="Repeat your new password"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                />
              </div>

              <button
                id="submit-btn"
                type="submit"
                class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition focus:outline-none focus:ring-2 focus:ring-primary/50 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Update Password
              </button>
            </form>
          )}

          <p class="mt-6 text-center text-sm text-muted-foreground">
            <a href="/login" class="text-primary font-medium hover:underline">
              Back to login
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.VITE_SUPABASE_URL || '';
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.VITE_SUPABASE_PUBLISHABLE_KEY || '';

    // Disable button while verifying if there's a hash with a token
    const hash = window.location.hash;
    if (hash && hash.includes('access_token')) {
      const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Verifying...';
      }
    }

    async function exchangeToken() {
      const hash = window.location.hash;
      if (!hash || !hash.includes('access_token')) return;

      // Parse the hash fragment
      const params = new URLSearchParams(hash.substring(1));
      const accessToken = params.get('access_token');
      const refreshToken = params.get('refresh_token');
      const type = params.get('type');

      if (type !== 'recovery' || !accessToken) return;

      // Create client and set the session
      const supabase = createClient(supabaseUrl, supabaseKey);
      const { error } = await supabase.auth.setSession({
        access_token: accessToken,
        refresh_token: refreshToken || '',
      });

      if (error) {
        console.error('Failed to exchange recovery token:', error.message);
        const status = document.getElementById('token-status');
        if (status) {
          status.textContent = 'Failed to verify reset token. Please request a new password reset link.';
          status.classList.remove('hidden');
          status.classList.add('text-destructive');
        }
        return;
      }

      // Clean the URL (remove hash) and show success indicator
      window.history.replaceState(null, '', window.location.pathname);

      // Enable the form
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Update Password';
      }

      // Show a success message
      const status = document.getElementById('token-status');
      if (status) {
        status.textContent = 'Token verified. You can now set a new password.';
        status.classList.remove('hidden');
        status.classList.add('text-green-500');
      }
    }

    exchangeToken();
  </script>

  {success && (
    <script is:inline>
      setTimeout(function() { window.location.href = '/login'; }, 2000);
    </script>
  )}
</Shop>
