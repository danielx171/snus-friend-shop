---
export const prerender = false;

import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { actions } from 'astro:actions';
import { tenant } from '@/config/tenant';

const result = Astro.getActionResult(actions.auth.updatePassword);

const errorMessage = result?.error?.message;
const success = result?.data?.success;
---

<Shop
  title={`Update Password | ${tenant.name}`}
  description="Set a new password for your account."
  noindex={true}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Update Password' }]} />

      <div class="max-w-md mx-auto">
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8">
          <h1 class="text-3xl font-bold tracking-tight mb-2 text-center">Update Password</h1>
          <p class="text-muted-foreground text-center mb-8">
            Choose a new password for your account.
          </p>

          {errorMessage && (
            <div class="mb-6 rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-center">
              <p class="text-sm text-destructive font-medium">{errorMessage}</p>
            </div>
          )}

          {success ? (
            <div class="rounded-lg border border-primary/30 bg-primary/5 p-4 text-center">
              <p class="text-sm text-foreground font-medium mb-1">Password updated!</p>
              <p class="text-sm text-muted-foreground">Redirecting to login...</p>
            </div>
          ) : (
            <form method="POST" action={actions.auth.updatePassword} class="space-y-5">
              <div>
                <label for="password" class="block text-sm font-medium text-foreground mb-1.5">
                  New password
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  autocomplete="new-password"
                  minlength="8"
                  placeholder="At least 8 characters"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                />
              </div>

              <div>
                <label for="confirmPassword" class="block text-sm font-medium text-foreground mb-1.5">
                  Confirm new password
                </label>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                  autocomplete="new-password"
                  minlength="8"
                  placeholder="Repeat your new password"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                />
              </div>

              <button
                type="submit"
                class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition focus:outline-none focus:ring-2 focus:ring-primary/50"
              >
                Update Password
              </button>
            </form>
          )}

          <p class="mt-6 text-center text-sm text-muted-foreground">
            <a href="/login" class="text-primary font-medium hover:underline">
              Back to login
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  {success && (
    <script is:inline>
      setTimeout(function() { window.location.href = '/login'; }, 2000);
    </script>
  )}
</Shop>
