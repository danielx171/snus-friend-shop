---
export const prerender = true;
import { Image } from 'astro:assets';
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { brandColors, defaultBrandColor } from '@/data/brand-colors';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  const products = await getCollection('products');

  return brands.map((brand) => ({
    params: { slug: brand.id },
    props: {
      brand,
      products: products.filter((p) => p.data.brandSlug === brand.id),
    },
  }));
}

const { brand, products } = Astro.props;
const b = brand.data;

// Strength dots mapping (same as products/index.astro)
const strengthDots: Record<string, number> = {
  light: 1,
  normal: 2,
  strong: 3,
  'extra-strong': 4,
  'super-strong': 5,
};

const countryNames: Record<string, string> = {
  SE: 'Sweden',
  DK: 'Denmark',
  NO: 'Norway',
  US: 'United States',
  UK: 'United Kingdom',
  DE: 'Germany',
  FI: 'Finland',
  CH: 'Switzerland',
};

const countryLabel = b.countryCode ? (countryNames[b.countryCode] ?? b.countryCode) : '';
const bColor = brandColors[brand.id] ?? defaultBrandColor;

const nicotineValues = products.map((p) => p.data.nicotineContent).filter(Boolean);
const minMg = nicotineValues.length ? Math.min(...nicotineValues) : 0;
const maxMg = nicotineValues.length ? Math.max(...nicotineValues) : 0;

const metaDescription = b.description
  ? (b.description.length > 160 ? b.description.slice(0, 157) + '...' : b.description)
  : `Shop ${b.name} nicotine pouches at SnusFriend. Browse the full range of ${b.name} products with free EU shipping on qualifying orders.`;
---

<Shop
  title={`${b.name} Nicotine Pouches | SnusFriend`}
  description={metaDescription}
  canonical={`/brands/${brand.id}`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${b.name} Nicotine Pouches`,
    "description": metaDescription,
    "url": `https://snusfriends.com/brands/${brand.id}`,
    "numberOfItems": products.length,
    "provider": {
      "@type": "Organization",
      "name": "SnusFriend",
      "url": "https://snusfriends.com"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Brand",
    "name": b.name,
    ...(b.logoUrl && { "logo": b.logoUrl }),
    "description": metaDescription,
    "url": `https://snusfriends.com/brands/${brand.id}`,
    ...(b.manufacturer && { "manufacturer": { "@type": "Organization", "name": b.manufacturer } })
  })} />

  <div class="mx-auto max-w-7xl px-4 py-8">
    <Breadcrumb items={[
      { label: 'Brands', href: '/brands' },
      { label: b.name },
    ]} />

    <!-- Brand hero banner -->
    <div class="mb-8 overflow-hidden rounded-2xl" style={`background: linear-gradient(135deg, ${bColor}dd, ${bColor}88);`}>
      <div class="flex flex-col items-start gap-6 p-6 sm:flex-row sm:items-center sm:p-8">
        {/* Brand logo or styled name */}
        {b.logoUrl ? (
          <div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-white/20 backdrop-blur">
            <Image
              src={b.logoUrl}
              alt={`${b.name} logo`}
              width={80}
              height={80}
              loading="eager"
              format="webp"
              class="h-full w-full object-contain"
            />
          </div>
        ) : (
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-xl bg-white/20 backdrop-blur">
            <span class="text-2xl font-bold text-white">
              {b.name.split(/[\s-]+/).slice(0, 2).map((w: string) => w[0]?.toUpperCase() ?? '').join('')}
            </span>
          </div>
        )}

        <div class="flex-1">
          <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl" style="font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;">
            {b.name}
          </h1>

          {/* Metadata chips */}
          <div class="mt-3 flex flex-wrap items-center gap-2">
            {countryLabel && (
              <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-medium text-white/90 backdrop-blur">
                {countryLabel}
              </span>
            )}
            {b.manufacturer && (
              <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-medium text-white/90 backdrop-blur">
                {b.manufacturer}
              </span>
            )}
            <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-medium text-white/90 backdrop-blur">
              {products.length} products
            </span>
            {minMg > 0 && (
              <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-medium text-white/90 backdrop-blur">
                {minMg}-{maxMg} mg
              </span>
            )}
          </div>
        </div>
      </div>
    </div>

    {/* Sub-page navigation */}
    <div class="mb-6 flex flex-wrap gap-2">
      <a href={`/brands/${brand.id}`} class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">All Products</a>
      <a href={`/brands/${brand.id}/flavours`} class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground hover:border-primary/30 transition">Flavours</a>
      <a href={`/brands/${brand.id}/strengths`} class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground hover:border-primary/30 transition">Strengths</a>
      <a href={`/brands/${brand.id}/review`} class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-foreground hover:border-primary/30 transition">Review</a>
    </div>

    {/* Collapsible description */}
    {b.description && (
      <details class="mb-8 group">
        <summary class="cursor-pointer text-sm font-medium text-primary hover:underline list-none">
          <span class="group-open:hidden">About {b.name} — Read more</span>
          <span class="hidden group-open:inline">About {b.name} — Show less</span>
        </summary>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-muted-foreground">
          {b.description}
        </p>
      </details>
    )}

    <!-- Products section -->
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-xl font-semibold text-foreground">
        {products.length > 0 ? `${b.name} Products` : 'Products'}
      </h2>
      <p class="text-sm text-muted-foreground">
        {products.length} {products.length === 1 ? 'product' : 'products'}
      </p>
    </div>

    <!-- Product grid (matches products/index.astro style) -->
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4 xl:gap-6">
      {products.map((product) => {
        const dots = strengthDots[product.data.strengthKey] ?? 2;
        const price = product.data.prices?.pack1;
        return (
          <a
            href={`/products/${product.id}`}
            class="group rounded-xl border border-border bg-card/50 p-3 backdrop-blur transition hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 sm:p-4"
          >
            {/* Product image */}
            {product.data.imageUrl ? (
              <div class="mb-3 aspect-square overflow-hidden rounded-lg bg-muted/20">
                <Image
                  src={product.data.imageUrl}
                  alt={product.data.name}
                  width={300}
                  height={300}
                  loading="lazy"
                  format="webp"
                  quality={80}
                  class="h-full w-full object-contain transition group-hover:scale-105"
                />
              </div>
            ) : (
              <div class="mb-3 flex aspect-square items-center justify-center rounded-lg bg-muted/20">
                <svg
                  class="h-10 w-10 text-muted-foreground/30"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1"
                >
                  <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
            )}

            {/* Brand */}
            <p class="mb-0.5 truncate text-xs text-muted-foreground">
              {product.data.brand}
            </p>

            {/* Product name */}
            <h3 class="mb-1.5 line-clamp-2 text-sm font-semibold leading-snug text-foreground group-hover:text-primary">
              {product.data.name}
            </h3>

            {/* Strength dots */}
            <div class="mb-2 flex items-center gap-1" role="img" aria-label={`Strength: ${product.data.strengthKey}`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <span
                  class={`inline-block h-1.5 w-1.5 rounded-full ${
                    i < dots ? 'bg-primary' : 'bg-muted-foreground/20'
                  }`}
                />
              ))}
              <span class="ml-1 text-xs text-muted-foreground">
                {product.data.nicotineContent > 0 ? `${product.data.nicotineContent}mg` : ''}
              </span>
            </div>

            {/* Price */}
            {price != null && (
              <div class="flex items-baseline gap-1.5">
                <span class="text-base font-bold text-foreground">
                  &euro;{price.toFixed(2)}
                </span>
                {product.data.comparePrice != null && product.data.comparePrice > price && (
                  <span class="text-xs text-muted-foreground line-through">
                    &euro;{product.data.comparePrice.toFixed(2)}
                  </span>
                )}
              </div>
            )}
          </a>
        );
      })}

      {/* Empty state */}
      {products.length === 0 && (
        <div class="col-span-full py-20 text-center">
          <p class="text-lg text-muted-foreground">
            No products found for {b.name} yet. Check back soon.
          </p>
        </div>
      )}
    </div>
  </div>
</Shop>
