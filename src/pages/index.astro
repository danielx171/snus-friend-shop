---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import { tenant } from '@/config/tenant';
import { getCollection } from 'astro:content';
import ProductCard from '@/components/astro/ProductCard.astro';
import RecentlyViewedIsland from '@/components/react/RecentlyViewedIsland';
import RecommendationsIsland from '@/components/react/RecommendationsIsland';
import { brandColors, defaultBrandColor } from '@/data/brand-colors';

const allProducts = await getCollection('products');
const allBrands = await getCollection('brands');

// Best sellers: products tagged "popular" by Nyehandel (real sales data),
// with brand diversity (max 1 per brand) so the grid showcases variety.
// Secondary sort by name for stable ordering when badges are equal.
const sortedByPopularity = [...allProducts]
  .filter((p) => p.data.imageUrl)
  .sort((a, b) => {
    const aPopular = a.data.badgeKeys.includes('popular') ? 1 : 0;
    const bPopular = b.data.badgeKeys.includes('popular') ? 1 : 0;
    if (bPopular !== aPopular) return bPopular - aPopular;
    return a.data.name.localeCompare(b.data.name);
  });
const bestSellers: typeof sortedByPopularity = [];
const brandCount: Record<string, number> = {};
for (const p of sortedByPopularity) {
  if (bestSellers.length >= 8) break;
  const b = p.data.brand;
  if ((brandCount[b] ?? 0) >= 1) continue;
  brandCount[b] = (brandCount[b] ?? 0) + 1;
  bestSellers.push(p);
}

// Brands sorted alphabetically — only those with at least one product
const brandSlugsWithProducts = new Set(allProducts.map((p) => p.data.brandSlug));
const activeBrands = allBrands.filter((b) => brandSlugsWithProducts.has(b.id));
const brands = [...activeBrands].sort((a, b) => a.data.name.localeCompare(b.data.name));
const heroDescription = `Shop ${allProducts.length}+ nicotine pouches from ${brands.length || 57} leading brands. Fast EU-wide delivery, loyalty rewards, and the best prices online.`;

// New Arrivals: products with 'new' badge or most recently updated (must have images)
const newArrivals = allProducts
  .filter((p) => p.data.imageUrl && (p.data.badgeKeys.includes('new') || p.data.badgeKeys.includes('NewPrice')))
  .sort((a, b) => (b.data.updatedAt ?? '').localeCompare(a.data.updatedAt ?? ''))
  .slice(0, 4);

// Staff Picks: curated top-rated products across diverse brands (1 per brand)
const staffPickBrands = ['zyn', 'velo', 'loop', 'skruf'];
const staffPicks = staffPickBrands
  .map((slug) => {
    const brandProducts = sortedByPopularity.filter((p) => p.data.brandSlug === slug && p.data.imageUrl);
    return brandProducts[0];
  })
  .filter(Boolean);

// Pick 4 hero products with diverse brand colors for the hero image cluster
const heroBrandTargets = ['zyn', 'velo', 'siberia', 'loop'];
const heroProducts = heroBrandTargets
  .map((slug) => allProducts.find((p) => p.data.brandSlug === slug && p.data.imageUrl))
  .filter(Boolean)
  .slice(0, 4);

// Fallback: if we don't have those brands, pick popular ones with images
if (heroProducts.length < 4) {
  for (const p of sortedByPopularity) {
    if (heroProducts.length >= 4) break;
    if (p.data.imageUrl && !heroProducts.some((h) => h!.data.brandSlug === p.data.brandSlug)) {
      heroProducts.push(p);
    }
  }
}
---

<Shop
  title={tenant.seo.defaultTitle}
  description={heroDescription}
  ogImage={tenant.seo.ogImage}
>
  <!-- Hero — Split layout: text left, product images right -->
  <section class="relative overflow-hidden border-b border-border" style={`background: hsl(var(--hero-bg));`}>
    <div class="absolute inset-0" style={`background: linear-gradient(to bottom right, hsl(var(--hero-gradient-from)), hsl(var(--hero-gradient-via)), hsl(var(--hero-gradient-to)));`} />
    <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-8 px-6 py-16 sm:py-20 lg:flex-row lg:gap-12 lg:py-24">

      <!-- Left: text + stats + CTAs -->
      <div class="flex-1 text-center lg:text-left">
        <p class="mb-3 text-sm font-medium uppercase tracking-widest" style={`color: hsl(var(--hero-muted));`}>
          Europe's Nicotine Pouch Shop
        </p>
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-[3.5rem] lg:leading-[1.1]" style={`color: hsl(var(--hero-text)); font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;`}>
          Premium Nicotine Pouches
        </h1>
        <p class="mx-auto mt-4 max-w-xl text-lg lg:mx-0" style={`color: hsl(var(--hero-muted));`}>
          {heroDescription}
        </p>

        <!-- Stats row -->
        <div class="mt-8 flex justify-center gap-8 lg:justify-start">
          <div>
            <div class="text-2xl font-bold" style={`color: hsl(var(--hero-text));`}>{allProducts.length}+</div>
            <div class="text-xs" style={`color: hsl(var(--hero-muted));`}>Cans</div>
          </div>
          <div class="h-10 w-px" style={`background: hsl(var(--hero-divider) / 0.1);`} />
          <div>
            <div class="text-2xl font-bold" style={`color: hsl(var(--hero-text));`}>{brands.length}</div>
            <div class="text-xs" style={`color: hsl(var(--hero-muted));`}>Brands</div>
          </div>
          <div class="h-10 w-px" style={`background: hsl(var(--hero-divider) / 0.1);`} />
          <div>
            <div class="text-2xl font-bold" style={`color: hsl(var(--hero-text));`}>Free</div>
            <div class="text-xs" style={`color: hsl(var(--hero-muted));`}>EU Shipping</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
          <a
            href="/nicotine-pouches"
            class="inline-flex h-12 items-center rounded-lg px-8 text-base font-semibold shadow-lg transition"
            style={`background: hsl(var(--hero-cta-bg)); color: hsl(var(--hero-cta-text));`}
          >
            Shop All Pouches
          </a>
          <a
            href="/flavor-quiz"
            class="inline-flex h-12 items-center rounded-lg border px-8 text-base font-semibold transition"
            style={`border-color: hsl(var(--hero-text) / 0.2); color: hsl(var(--hero-text));`}
          >
            Take the Flavour Quiz
          </a>
        </div>
      </div>

      <!-- Right: product can cluster -->
      <div class="hidden flex-1 items-center justify-center lg:flex">
        <div class="relative h-80 w-80">
          {heroProducts[0] && (
            <img
              src={heroProducts[0]!.data.imageUrl}
              alt={heroProducts[0]!.data.name}
              width="180"
              height="180"
              class="absolute left-4 top-2 rounded-2xl shadow-2xl shadow-black/30"
              style="transform: rotate(-6deg);"
              loading="eager"
            />
          )}
          {heroProducts[1] && (
            <img
              src={heroProducts[1]!.data.imageUrl}
              alt={heroProducts[1]!.data.name}
              width="160"
              height="160"
              class="absolute right-0 top-8 rounded-2xl shadow-2xl shadow-black/30"
              style="transform: rotate(4deg);"
              loading="eager"
            />
          )}
          {heroProducts[2] && (
            <img
              src={heroProducts[2]!.data.imageUrl}
              alt={heroProducts[2]!.data.name}
              width="150"
              height="150"
              class="absolute bottom-4 left-12 rounded-2xl shadow-2xl shadow-black/30"
              style="transform: rotate(3deg);"
              loading="eager"
            />
          )}
          {heroProducts[3] && (
            <img
              src={heroProducts[3]!.data.imageUrl}
              alt={heroProducts[3]!.data.name}
              width="140"
              height="140"
              class="absolute bottom-0 right-8 rounded-2xl shadow-2xl shadow-black/30"
              style="transform: rotate(-3deg);"
              loading="eager"
            />
          )}
        </div>
      </div>

      <!-- Mobile: horizontal product strip -->
      <div class="flex gap-4 overflow-x-auto pb-2 lg:hidden snap-x snap-mandatory">
        {heroProducts.map((p) => p && (
          <img
            src={p.data.imageUrl}
            alt={p.data.name}
            width="96"
            height="96"
            class="flex-shrink-0 snap-center rounded-xl shadow-lg shadow-black/20"
            loading="eager"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Purchase-based recommendations (logged-in users only) -->
  <RecommendationsIsland
    client:idle
    productsJson={JSON.stringify(allProducts.slice(0, 200).map((p) => ({
      slug: p.id,
      name: p.data.name,
      brand: p.data.brand,
      brandSlug: p.data.brandSlug,
      flavorKey: p.data.flavorKey,
      imageUrl: p.data.imageUrl,
      ratings: p.data.ratings,
      prices: { pack1: p.data.prices.pack1 },
    })))}
  />

  <!-- Recently Viewed (client-side, shows only if user has browsing history) -->
  <RecentlyViewedIsland
    client:idle
    productsJson={JSON.stringify(allProducts.slice(0, 200).map((p) => ({
      slug: p.id,
      name: p.data.name,
      brand: p.data.brand,
      imageUrl: p.data.imageUrl,
      prices: { pack1: p.data.prices.pack1 },
    })))}
  />

  <!-- Best Sellers -->
  <section id="best-sellers" class="border-b border-border bg-background py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mb-10 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Best Sellers</h2>
          <p class="mt-2 text-muted-foreground">Our most popular nicotine pouches this week</p>
        </div>
        <a href="/products" class="hidden text-sm font-medium text-primary hover:underline sm:block">
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:gap-6">
        {bestSellers.length > 0 ? (
          bestSellers.map((product) => (
            <ProductCard
              slug={product.id}
              name={product.data.name}
              brand={product.data.brand}
              brandSlug={product.data.brandSlug}
              imageUrl={product.data.imageUrl}
              prices={product.data.prices}
              stock={product.data.stock}
              nicotineContent={product.data.nicotineContent}
              strengthKey={product.data.strengthKey}
              flavorKey={product.data.flavorKey}
              ratings={product.data.ratings}
              badgeKeys={product.data.badgeKeys}
            />
          ))
        ) : (
          <div role="status" aria-label="Loading cans" class="col-span-full grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:gap-6">
            {Array.from({ length: 8 }).map(() => (
              <div class="group rounded-xl border border-border bg-card/50 p-4 backdrop-blur">
                <div class="mb-3 aspect-square rounded-lg bg-muted/30 animate-pulse" />
                <div class="mb-2 h-4 w-3/4 rounded bg-muted/30 animate-pulse" />
                <div class="h-3 w-1/2 rounded bg-muted/30 animate-pulse" />
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Staff Picks -->
  {staffPicks.length > 0 && (
    <section id="staff-picks" class="border-b border-border bg-card/30 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Staff Picks</h2>
          <p class="mt-2 text-muted-foreground">Curated by our editorial team — one standout from each top brand</p>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 xl:gap-6">
          {staffPicks.map((product) => product && (
            <ProductCard
              slug={product.id}
              name={product.data.name}
              brand={product.data.brand}
              brandSlug={product.data.brandSlug}
              imageUrl={product.data.imageUrl}
              prices={product.data.prices}
              stock={product.data.stock}
              nicotineContent={product.data.nicotineContent}
              strengthKey={product.data.strengthKey}
              flavorKey={product.data.flavorKey}
              ratings={product.data.ratings}
              badgeKeys={product.data.badgeKeys}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- New Arrivals -->
  {newArrivals.length > 0 && (
    <section id="new-arrivals" class="border-b border-border bg-background py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10 flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold text-foreground sm:text-3xl">New Arrivals</h2>
            <p class="mt-2 text-muted-foreground">Latest additions and updated cans</p>
          </div>
          <a href="/products" class="hidden text-sm font-medium text-primary hover:underline sm:block">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 xl:gap-6">
          {newArrivals.map((product) => (
            <ProductCard
              slug={product.id}
              name={product.data.name}
              brand={product.data.brand}
              brandSlug={product.data.brandSlug}
              imageUrl={product.data.imageUrl}
              prices={product.data.prices}
              stock={product.data.stock}
              nicotineContent={product.data.nicotineContent}
              strengthKey={product.data.strengthKey}
              flavorKey={product.data.flavorKey}
              ratings={product.data.ratings}
              badgeKeys={product.data.badgeKeys}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why SnusFriend -->
  <section class="border-b border-border bg-background py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-6 text-center text-2xl font-bold text-foreground sm:text-3xl">
        Why Thousands of Europeans Shop at SnusFriend
      </h2>
      <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
        <p>
          SnusFriend exists for one reason: to give nicotine pouch users the selection, the
          information, and the service that mainstream tobacco retailers never bothered with.
          We stock <strong class="text-foreground">{allProducts.length}+ cans</strong> from
          <strong class="text-foreground">{brands.length} brands</strong> — from global leaders
          like ZYN and VELO to cult favourites like Siberia, LOOP, and Pablo — all in one place,
          all with transparent pricing and honest product descriptions.
        </p>
        <p>
          Because Google Ads bans nicotine advertising, you won't find us through flashy paid
          campaigns. Instead, we earn every visit by publishing the most thorough
          <a href="/blog" class="underline hover:text-foreground">guides and reviews</a> in the
          nicotine pouch space — fact-checked, regularly updated, and written for real users
          rather than search algorithms. That editorial approach shapes our entire store: every
          brand page includes the manufacturer, country of origin, strength range, and an honest
          description so you know exactly what you're buying.
        </p>
        <p>
          Orders ship from our EU warehouse within 24 hours, with tracking on every parcel and
          free shipping on orders over &euro;{tenant.freeShippingThreshold}. Our
          <a href="/rewards" class="underline hover:text-foreground">loyalty program</a> rewards
          repeat customers with points, quests, and exclusive perks — because the pouch community
          deserves better than one-and-done checkout experiences. We only sell to customers aged
          18 and over, and we comply with all applicable EU regulations on nicotine products.
        </p>
      </div>
    </div>
  </section>

  <!-- Shop by Brand -->
  <section class="border-b border-border bg-background py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-10 text-center text-2xl font-bold text-foreground sm:text-3xl">
        Shop by Brand
      </h2>
      <p class="mb-10 text-center text-muted-foreground">
        We carry all the brands you know and love &mdash; plus new favourites waiting to be discovered.
      </p>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {brands.length > 0 ? (
          brands.slice(0, 15).map((brand) => {
            const bColor = brandColors[brand.id] ?? defaultBrandColor;
            const tinAbbr = { 'white-fox': 'WF', 'nordic-spirit': 'NS', 'chainpop': 'CHAIN' } as any;
            const tLabel = tinAbbr[brand.id] ?? brand.data.name.toUpperCase();
            const tLen = tLabel.length;
            const tSize = tLen <= 2 ? '11px' : tLen <= 3 ? '10px' : tLen <= 4 ? '9px' : tLen <= 5 ? '8px' : '7px';
            const hexStr = bColor.replace(/^#/, '');
            const rVal = parseInt(hexStr.substring(0, 2), 16);
            const gVal = parseInt(hexStr.substring(2, 4), 16);
            const bVal = parseInt(hexStr.substring(4, 6), 16);
            const lum = (0.299 * rVal + 0.587 * gVal + 0.114 * bVal) / 255;
            const tColor = lum > 0.55 ? 'rgba(0,0,0,0.75)' : 'white';
            const dR = Math.max(0, rVal - 40);
            const dG = Math.max(0, gVal - 40);
            const dB = Math.max(0, bVal - 40);
            return (
              <a
                href={`/brands/${brand.id}`}
                class="group flex items-center gap-3 rounded-xl border border-border bg-card/60 p-3 transition hover:border-primary/30 hover:shadow-md"
              >
                <div
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full relative overflow-hidden"
                  style={`background: linear-gradient(135deg, ${bColor}, rgb(${dR},${dG},${dB}));`}
                >
                  <div class="absolute inset-[2px] rounded-full border border-white/25 pointer-events-none"></div>
                  <span class="relative z-[1] font-extrabold uppercase leading-none" style={`font-size: ${tSize}; color: ${tColor}; letter-spacing: 0.3px;`}>{tLabel}</span>
                </div>
                <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{brand.data.name}</span>
              </a>
            );
          })
        ) : (
          ['VELO', 'ZYN', 'LOOP', 'Siberia', 'PABLO'].map((name) => (
            <div class="flex items-center gap-3 rounded-xl border border-border bg-card/60 p-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/20 relative overflow-hidden">
                <div class="absolute inset-[2px] rounded-full border border-white/25 pointer-events-none"></div>
                <span class="relative z-[1] text-sm font-extrabold text-white">{name.substring(0, 3).toUpperCase()}</span>
              </div>
              <span class="text-sm font-medium text-foreground">{name}</span>
            </div>
          ))
        )}
      </div>
      <div class="mt-8 text-center">
        <a href="/brands" class="text-sm font-medium text-primary hover:underline">
          View all {brands.length > 0 ? brands.length : 57} brands &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Rewards & Gamification CTA -->
  <section class="border-b border-border py-16 sm:py-20" style={`background: hsl(var(--hero-bg));`}>
    <div class="mx-auto max-w-4xl px-4">
      <div class="flex flex-col items-center gap-8 text-center sm:flex-row sm:text-left">
        <div class="flex-1">
          <h2 class="text-2xl font-bold sm:text-3xl" style={`color: hsl(var(--hero-text)); font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;`}>
            Earn Rewards Every Time You Shop
          </h2>
          <p class="mt-3 text-base leading-relaxed" style={`color: hsl(var(--hero-muted));`}>
            Join SnusFriends Rewards — earn points on every order, spin the daily wheel for prizes, complete quests to unlock exclusive avatars, and climb the leaderboard. No competitor offers anything like it.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href="/rewards" class="inline-flex h-11 items-center justify-center rounded-lg px-6 text-sm font-semibold transition" style={`background: hsl(var(--hero-cta-bg)); color: hsl(var(--hero-cta-text));`}>
              Start Earning Points
            </a>
            <a href="/community" class="inline-flex h-11 items-center justify-center rounded-lg border px-6 text-sm font-semibold transition" style={`border-color: hsl(var(--hero-text) / 0.2); color: hsl(var(--hero-text));`}>
              View Leaderboard
            </a>
          </div>
        </div>
        <div class="flex gap-6 text-center">
          <div>
            <div class="text-3xl font-bold" style={`color: hsl(var(--hero-text));`}>🎡</div>
            <div class="mt-1 text-xs" style={`color: hsl(var(--hero-muted));`}>Daily Spin</div>
          </div>
          <div>
            <div class="text-3xl font-bold" style={`color: hsl(var(--hero-text));`}>⚡</div>
            <div class="mt-1 text-xs" style={`color: hsl(var(--hero-muted));`}>Quests</div>
          </div>
          <div>
            <div class="text-3xl font-bold" style={`color: hsl(var(--hero-text));`}>🏆</div>
            <div class="mt-1 text-xs" style={`color: hsl(var(--hero-muted));`}>Leaderboard</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-background py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">
        Ready to find your perfect pouch?
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Take our flavour quiz and get personalised recommendations in under a minute.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/flavor-quiz"
          class="inline-flex h-12 items-center rounded-lg bg-primary px-8 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition hover:bg-primary/90"
        >
          Take the Quiz
        </a>
        <a
          href="/products"
          class="inline-flex h-12 items-center rounded-lg border border-border bg-card/60 px-8 text-base font-semibold text-foreground backdrop-blur transition hover:bg-card"
        >
          Browse All Cans
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SnusFriend",
    "url": "https://snusfriends.com",
    "logo": "https://snusfriends.com/favicon.png",
    "description": `Europe's leading online shop for premium nicotine pouches. ${allProducts.length}+ products from ${brands.length || 57} brands.`,
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "support@snusfriends.com",
      "contactType": "customer service"
    },
    "sameAs": []
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SnusFriend",
    "url": "https://snusfriends.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://snusfriends.com/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Beginner mode: hide strong products from static sections -->
  <script is:inline>
  (function() {
    try {
      var raw = localStorage.getItem('snusfriend_beginner');
      if (!raw || raw !== 'true') return;
      var cards = document.querySelectorAll('[data-nicotine-mg]');
      for (var i = 0; i < cards.length; i++) {
        var mg = parseFloat(cards[i].getAttribute('data-nicotine-mg'));
        if (mg > 6) cards[i].style.display = 'none';
      }
    } catch(e) {}
  })();
  </script>
</Shop>
