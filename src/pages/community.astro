---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Community | ${tenant.name}`}
  description={`Join the ${tenant.name} community — share reviews, climb the leaderboard, and complete quests to earn rewards.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Community' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-3">Community</h1>
      <p class="text-lg text-muted-foreground mb-10">
        Connect with fellow pouch enthusiasts. Share reviews, earn points, and climb the ranks.
      </p>

      <!-- Leaderboard Preview -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-semibold">Leaderboard</h2>
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            Coming Soon
          </span>
        </div>
        <div class="space-y-3">
          {[1, 2, 3].map((rank) => (
            <div class="flex items-center gap-4 rounded-lg bg-muted/40 p-3">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">
                {rank}
              </span>
              <div class="flex-1">
                <div class="h-4 w-32 rounded bg-muted animate-pulse" />
              </div>
              <div class="h-4 w-16 rounded bg-muted animate-pulse" />
            </div>
          ))}
        </div>
        <p class="text-xs text-muted-foreground/60 mt-4 text-center">
          Leaderboard launches with our community beta.
        </p>
      </div>

      <!-- Recent Reviews -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-semibold">Recent Reviews</h2>
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            Coming Soon
          </span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {['VELO Freeze Max', 'ZYN Spearmint'].map((product) => (
            <div class="rounded-lg bg-muted/40 p-4">
              <div class="flex items-center gap-2 mb-2">
                <div class="flex gap-0.5">
                  {[1, 2, 3, 4, 5].map(() => (
                    <span class="text-primary/30">&#9733;</span>
                  ))}
                </div>
              </div>
              <p class="text-sm font-medium text-foreground mb-1">{product}</p>
              <div class="h-3 w-full rounded bg-muted animate-pulse mb-1" />
              <div class="h-3 w-2/3 rounded bg-muted animate-pulse" />
            </div>
          ))}
        </div>
        <p class="text-xs text-muted-foreground/60 mt-4 text-center">
          Be the first to leave a review when we launch.
        </p>
      </div>

      <!-- Quests Overview -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-semibold">Quests</h2>
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            Coming Soon
          </span>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {[
            { name: 'First Review', desc: 'Write your first product review', pts: 50 },
            { name: 'Flavour Explorer', desc: 'Try 5 different flavour categories', pts: 100 },
            { name: 'Brand Ambassador', desc: 'Review products from 10 brands', pts: 200 },
          ].map((quest) => (
            <div class="rounded-lg border border-border bg-background/50 p-4 text-center">
              <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
                <span class="text-lg text-primary">&#9734;</span>
              </div>
              <h3 class="text-sm font-semibold mb-1">{quest.name}</h3>
              <p class="text-xs text-muted-foreground mb-2">{quest.desc}</p>
              <span class="text-xs font-medium text-primary">{quest.pts} pts</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Shop>
