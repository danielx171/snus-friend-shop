---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import QuestBoardIsland from '@/components/react/QuestBoardIsland';
import LeaderboardIsland from '@/components/react/LeaderboardIsland';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Community | ${tenant.name}`}
  description={`Join the ${tenant.name} community — share reviews, climb the leaderboard, and complete quests to earn rewards.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Community' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-3">Community</h1>
      <p class="text-lg text-muted-foreground mb-10">
        Connect with fellow pouch enthusiasts. Share reviews, earn points, and climb the ranks.
      </p>

      <!-- Leaderboard -->
      <div class="mb-8">
        <LeaderboardIsland client:visible />
      </div>

      <!-- Recent Reviews -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-semibold">Recent Reviews</h2>
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            Coming Soon
          </span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {['VELO Freeze Max', 'ZYN Spearmint'].map((product) => (
            <div class="rounded-lg bg-muted/40 p-4">
              <div class="flex items-center gap-2 mb-2">
                <div class="flex gap-0.5">
                  {[1, 2, 3, 4, 5].map(() => (
                    <span class="text-primary/30">&#9733;</span>
                  ))}
                </div>
              </div>
              <p class="text-sm font-medium text-foreground mb-1">{product}</p>
              <div class="h-3 w-full rounded bg-muted animate-pulse mb-1" />
              <div class="h-3 w-2/3 rounded bg-muted animate-pulse" />
            </div>
          ))}
        </div>
        <p class="text-xs text-muted-foreground mt-4 text-center">
          Be the first to leave a review when we launch.
        </p>
      </div>

      <!-- Quests -->
      <div class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">Quests</h2>
        <QuestBoardIsland client:idle />
      </div>
    </div>
  </section>
</Shop>
