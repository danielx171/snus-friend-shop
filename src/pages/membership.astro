---
export const prerender = false;

import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';

// Fetch reputation levels from DB
const supabase = Astro.locals.supabase;

const { data: tiers } = await supabase
  .from('reputation_levels')
  .select('level, name, min_points, badge_color, perks')
  .order('level', { ascending: true });

// Check if user is logged in and fetch their reputation
const user = Astro.locals.user;
let userReputation: { level: number; lifetime_earned: number; next_level_min_points: number | null; next_level_name: string | null } | null = null;

if (user) {
  const { data } = await supabase
    .from('user_reputation')
    .select('level, lifetime_earned, next_level_min_points, next_level_name')
    .eq('user_id', user.id)
    .single();
  userReputation = data;
}

// Badge color to CSS class mapping
const badgeColorMap: Record<string, { bg: string; text: string; ring: string; gradient: string }> = {
  gray:   { bg: 'bg-zinc-500/15', text: 'text-zinc-400', ring: 'ring-zinc-500/30', gradient: 'from-zinc-500/20 to-zinc-600/10' },
  blue:   { bg: 'bg-blue-500/15', text: 'text-blue-400', ring: 'ring-blue-500/30', gradient: 'from-blue-500/20 to-blue-600/10' },
  green:  { bg: 'bg-emerald-500/15', text: 'text-emerald-400', ring: 'ring-emerald-500/30', gradient: 'from-emerald-500/20 to-emerald-600/10' },
  purple: { bg: 'bg-purple-500/15', text: 'text-purple-400', ring: 'ring-purple-500/30', gradient: 'from-purple-500/20 to-purple-600/10' },
  gold:   { bg: 'bg-amber-500/15', text: 'text-amber-400', ring: 'ring-amber-500/30', gradient: 'from-amber-500/20 to-amber-600/10' },
};

const tierList = tiers ?? [];
---

<Shop
  title={`Membership Tiers | ${tenant.name}`}
  description={`Discover ${tenant.name} membership tiers — from Newcomer to Legend. Earn points, unlock perks, and level up your nicotine pouch experience.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Rewards', href: '/rewards' }, { label: 'Membership' }]} />

      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight mb-3">Membership Tiers</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Every purchase and interaction earns you SnusPoints. The more you earn, the higher you climb — unlocking exclusive perks at every level.
        </p>
      </div>

      <!-- User progress banner (logged in only) -->
      {userReputation && (
        <div class="rounded-xl border border-primary/30 bg-primary/5 p-6 mb-10">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <p class="text-sm text-muted-foreground">Your current tier</p>
              <p class="text-2xl font-bold text-primary">
                {tierList.find(t => t.level === userReputation!.level)?.name ?? 'Newcomer'}
              </p>
              <p class="text-sm text-muted-foreground mt-1">
                {userReputation.lifetime_earned.toLocaleString()} lifetime points earned
              </p>
            </div>
            {userReputation.next_level_name && userReputation.next_level_min_points && (
              <div class="w-full sm:w-64">
                <div class="flex justify-between text-xs text-muted-foreground mb-1.5">
                  <span>Progress</span>
                  <span>{userReputation.next_level_name} ({userReputation.next_level_min_points.toLocaleString()} pts)</span>
                </div>
                <div class="w-full h-2.5 bg-background/50 rounded-full overflow-hidden border border-border/50">
                  <div
                    class="h-full bg-primary rounded-full transition-all"
                    style={`width: ${Math.min(100, Math.round((userReputation.lifetime_earned / userReputation.next_level_min_points) * 100))}%`}
                  />
                </div>
                <p class="text-xs text-muted-foreground mt-1.5">
                  {(userReputation.next_level_min_points - userReputation.lifetime_earned).toLocaleString()} points to go
                </p>
              </div>
            )}
            {!userReputation.next_level_name && (
              <div class="text-sm text-primary font-medium">
                You have reached the highest tier!
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Visual tier progression -->
      <div class="relative mb-12">
        <!-- Connecting line (hidden on mobile, visible on desktop) -->
        <div class="hidden sm:block absolute top-8 left-8 right-8 h-0.5 bg-border/50 z-0" aria-hidden="true"></div>
        <div class="flex flex-col sm:flex-row justify-between gap-4 sm:gap-0 relative z-10">
          {tierList.map((tier) => {
            const colors = badgeColorMap[tier.badge_color] ?? badgeColorMap.gray;
            const isCurrent = userReputation?.level === tier.level;
            return (
              <div class="flex sm:flex-col items-center gap-3 sm:gap-2 sm:text-center">
                <div class:list={[
                  'flex h-16 w-16 shrink-0 items-center justify-center rounded-full border-2 text-xl font-bold transition',
                  isCurrent ? 'border-primary bg-primary/20 ring-4 ring-primary/20 scale-110' : `border-border/50 ${colors.bg}`,
                ]}>
                  <span class:list={[isCurrent ? 'text-primary' : colors.text, 'text-lg font-bold']}>
                    {tier.level}
                  </span>
                </div>
                <div class="sm:mt-1">
                  <p class:list={['text-sm font-semibold', isCurrent ? 'text-primary' : 'text-foreground']}>
                    {tier.name}
                  </p>
                  <p class="text-xs text-muted-foreground">
                    {tier.min_points === 0 ? 'Start here' : `${tier.min_points.toLocaleString()} pts`}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Tier detail cards -->
      <h2 class="text-2xl font-bold tracking-tight mb-6">What You Unlock</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
        {tierList.map((tier) => {
          const colors = badgeColorMap[tier.badge_color] ?? badgeColorMap.gray;
          const isCurrent = userReputation?.level === tier.level;
          const isUnlocked = userReputation ? userReputation.level >= tier.level : false;
          const perks = Array.isArray(tier.perks) ? tier.perks as string[] : [];

          return (
            <div class:list={[
              'rounded-xl border overflow-hidden transition-all',
              isCurrent
                ? 'border-primary/50 ring-2 ring-primary/20 shadow-lg shadow-primary/5'
                : 'border-border bg-card/60 backdrop-blur-sm',
            ]}>
              {/* Header */}
              <div class={`bg-gradient-to-r ${colors.gradient} px-5 py-4 border-b border-border/30`}>
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-bold text-foreground">{tier.name}</h3>
                    <p class="text-xs text-muted-foreground mt-0.5">
                      {tier.min_points === 0 ? 'Starting tier' : `${tier.min_points.toLocaleString()} points`}
                    </p>
                  </div>
                  <div class:list={[
                    'flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold',
                    colors.bg, colors.text,
                  ]}>
                    L{tier.level}
                  </div>
                </div>
                {isCurrent && (
                  <span class="inline-block mt-2 px-2 py-0.5 rounded-full bg-primary/20 text-primary text-xs font-medium">
                    Your tier
                  </span>
                )}
                {isUnlocked && !isCurrent && (
                  <span class="inline-block mt-2 px-2 py-0.5 rounded-full bg-emerald-500/20 text-emerald-400 text-xs font-medium">
                    Unlocked
                  </span>
                )}
              </div>

              {/* Perks list */}
              <ul class="p-5 space-y-2.5">
                {perks.map((perk) => (
                  <li class="flex items-start gap-2.5 text-sm text-muted-foreground">
                    <span class:list={['mt-0.5 shrink-0', isUnlocked ? 'text-primary' : 'text-muted-foreground/50']}>
                      {isUnlocked ? '\u2713' : '\u25CB'}
                    </span>
                    <span>{perk}</span>
                  </li>
                ))}
                {perks.length === 0 && (
                  <li class="text-sm text-muted-foreground italic">Perks coming soon</li>
                )}
              </ul>
            </div>
          );
        })}
      </div>

      <!-- How to earn points -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 mb-12">
        <h2 class="text-xl font-bold mb-4">How to Earn Points</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            { action: 'Place orders', detail: '1 point per EUR spent', icon: '\uD83D\uDED2' },
            { action: 'Write reviews', detail: '50 points per review', icon: '\u2B50' },
            { action: 'Daily spin', detail: 'Up to 50 points per day', icon: '\uD83C\uDFA1' },
            { action: 'Complete quests', detail: 'Bonus points for challenges', icon: '\uD83C\uDFAF' },
            { action: 'Refer a friend', detail: 'Both earn 200 points', icon: '\uD83E\uDD1D' },
            { action: 'Birthday bonus', detail: 'Double points on your birthday', icon: '\uD83C\uDF82' },
          ].map((item) => (
            <div class="flex items-start gap-3">
              <span class="text-xl shrink-0" aria-hidden="true">{item.icon}</span>
              <div>
                <p class="text-sm font-medium text-foreground">{item.action}</p>
                <p class="text-xs text-muted-foreground">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      {!user ? (
        <div class="rounded-xl border border-primary/30 bg-primary/5 p-8 text-center">
          <h2 class="text-xl font-bold mb-2">Start Your Journey</h2>
          <p class="text-muted-foreground text-sm max-w-md mx-auto mb-6">
            Create a free account and start earning points on every purchase. Your first spin is waiting!
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="/register"
              class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
            >
              Create Free Account
            </a>
            <a
              href="/rewards"
              class="inline-flex items-center justify-center rounded-lg border border-border px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-muted/50"
            >
              View Rewards
            </a>
          </div>
        </div>
      ) : (
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8 text-center">
          <h2 class="text-xl font-bold mb-2">Keep Earning</h2>
          <p class="text-muted-foreground text-sm max-w-md mx-auto mb-6">
            Every purchase gets you closer to the next tier. Check your rewards or start shopping.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="/products"
              class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
            >
              Start Shopping
            </a>
            <a
              href="/rewards"
              class="inline-flex items-center justify-center rounded-lg border border-border px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-muted/50"
            >
              View Rewards
            </a>
          </div>
        </div>
      )}
    </div>
  </section>
</Shop>
