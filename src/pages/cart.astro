---
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import CartIsland from '@/components/react/CartIsland';
---

<Shop
  title="Your Cart | SnusFriend"
  noindex={true}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Cart' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-8">Your Cart</h1>

      <div id="cart-root">
        <CartIsland client:load />
      </div>
    </div>
  </section>
</Shop>
