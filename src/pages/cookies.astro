---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Cookie Policy | ${tenant.name}`}
  description={`Cookie policy for ${tenant.name}. Learn what cookies we use and how to manage your preferences.`}
  canonical="/cookies"
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Cookie Policy' }]} />

      <div class="prose prose-invert max-w-none
        prose-headings:text-foreground prose-p:text-muted-foreground
        prose-a:text-primary prose-strong:text-foreground
        prose-li:text-muted-foreground prose-hr:border-border">

        <h1 class="text-4xl font-bold tracking-tight mb-2">Cookie Policy</h1>
        <p class="text-sm text-muted-foreground mb-8">Effective date: 26 March 2026</p>

        <h2>What Are Cookies?</h2>
        <p>
          Cookies are small text files stored on your device when you visit a website. They help
          the site remember your preferences, keep you logged in, and understand how you use the
          site. Some cookies are essential for the site to work; others help us improve your
          experience.
        </p>

        <h2>Essential Cookies</h2>
        <p>
          These cookies are strictly necessary for the Site to function and cannot be disabled.
          They include:
        </p>
        <div class="overflow-x-auto not-prose mb-6">
          <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
            <thead class="bg-card/60">
              <tr>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Cookie</th>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Purpose</th>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Duration</th>
              </tr>
            </thead>
            <tbody class="text-muted-foreground">
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-xs">sb-*-auth-token</td>
                <td class="p-3">Authentication session (Supabase)</td>
                <td class="p-3">Session / 1 year</td>
              </tr>
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-xs">cart</td>
                <td class="p-3">Shopping cart contents</td>
                <td class="p-3">30 days</td>
              </tr>
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-xs">cookie-consent</td>
                <td class="p-3">Records your cookie preferences</td>
                <td class="p-3">1 year</td>
              </tr>
              <tr>
                <td class="p-3 font-mono text-xs">age-verified</td>
                <td class="p-3">Records age verification status</td>
                <td class="p-3">Session</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>Analytics Cookies</h2>
        <p>
          These cookies help us understand how visitors use the Site so we can improve it.
          Data is collected in anonymised form. These are only set with your consent.
        </p>
        <div class="overflow-x-auto not-prose mb-6">
          <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
            <thead class="bg-card/60">
              <tr>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Cookie</th>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Purpose</th>
                <th class="text-left p-3 text-foreground font-medium border-b border-border">Duration</th>
              </tr>
            </thead>
            <tbody class="text-muted-foreground">
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-xs">ph_*</td>
                <td class="p-3">PostHog analytics &mdash; page views, feature usage</td>
                <td class="p-3">1 year</td>
              </tr>
              <tr>
                <td class="p-3 font-mono text-xs">_vercel_insights</td>
                <td class="p-3">Vercel Web Analytics &mdash; performance metrics</td>
                <td class="p-3">Session</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>Marketing Cookies</h2>
        <p>
          We do not currently use marketing or advertising cookies. If this changes in the
          future, we will update this policy and request your consent before setting any
          marketing cookies.
        </p>

        <h2>How to Manage Cookies</h2>
        <p>You can manage your cookie preferences in several ways:</p>
        <ul>
          <li>
            <strong>Cookie banner:</strong> When you first visit the Site, a cookie banner
            allows you to accept or decline non-essential cookies.
          </li>
          <li>
            <strong>Browser settings:</strong> Most browsers allow you to block or delete
            cookies through their settings. Note that blocking essential cookies may prevent
            the Site from functioning correctly.
          </li>
          <li>
            <strong>Opt-out links:</strong> PostHog respects the
            <a href="https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/DNT" target="_blank" rel="noopener noreferrer">Do Not Track</a>
            browser signal.
          </li>
        </ul>

        <h2>Changes to This Policy</h2>
        <p>
          We may update this Cookie Policy to reflect changes in our practices or for regulatory
          reasons. Changes will be posted on this page with an updated effective date.
        </p>

        <h2>Contact</h2>
        <p>
          If you have questions about our use of cookies, contact us at
          <a href={`mailto:${tenant.supportEmail}`}>{tenant.supportEmail}</a>. For more
          information about how we handle personal data, see our
          <a href="/privacy">Privacy Policy</a>.
        </p>
      </div>
    </div>
  </section>
</Shop>
