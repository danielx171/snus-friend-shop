---
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Flavour Quiz | ${tenant.name}`}
  description="Take our flavour quiz to discover your perfect nicotine pouch. Answer a few questions and get personalised recommendations."
  canonical="/flavor-quiz"
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Flavour Quiz' }]} />

      <div class="mx-auto max-w-lg text-center py-16">
        {/* Icon */}
        <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-2xl bg-primary/10 border border-primary/20">
          <svg class="h-10 w-10 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
        </div>

        <h1 class="text-3xl font-bold tracking-tight mb-4">Flavour Quiz</h1>

        <div class="rounded-xl border border-primary/20 bg-primary/5 backdrop-blur-sm p-6 mb-8">
          <span class="inline-flex items-center rounded-full bg-primary/10 border border-primary/20 px-3 py-0.5 text-xs font-semibold text-primary mb-3">
            Coming Soon
          </span>
          <p class="text-muted-foreground leading-relaxed">
            We're building a personalised flavour quiz to help you discover the perfect nicotine
            pouch. Answer a few quick questions about your taste preferences, desired strength,
            and format &mdash; and we'll recommend products tailored just for you.
          </p>
        </div>

        <div class="space-y-4 text-left mb-10">
          <h2 class="text-lg font-semibold text-foreground text-center">How it will work</h2>
          <div class="grid gap-3">
            <div class="flex items-start gap-3 rounded-lg border border-border bg-card/40 p-4">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-primary text-sm font-semibold flex-shrink-0">1</span>
              <div>
                <p class="text-sm font-medium text-foreground">Choose your flavour profile</p>
                <p class="text-xs text-muted-foreground">Minty fresh, fruity burst, coffee lover, or something bold?</p>
              </div>
            </div>
            <div class="flex items-start gap-3 rounded-lg border border-border bg-card/40 p-4">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-primary text-sm font-semibold flex-shrink-0">2</span>
              <div>
                <p class="text-sm font-medium text-foreground">Pick your strength</p>
                <p class="text-xs text-muted-foreground">From mild and relaxing to extra strong for experienced users.</p>
              </div>
            </div>
            <div class="flex items-start gap-3 rounded-lg border border-border bg-card/40 p-4">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-primary text-sm font-semibold flex-shrink-0">3</span>
              <div>
                <p class="text-sm font-medium text-foreground">Get personalised picks</p>
                <p class="text-xs text-muted-foreground">We'll match you with products from our catalog of 700+ pouches.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/products"
            class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition hover:bg-primary/90"
          >
            Browse All Products
          </a>
          <a
            href="/"
            class="inline-flex h-12 items-center justify-center rounded-lg border border-border bg-card/60 px-8 text-base font-semibold text-foreground backdrop-blur transition hover:bg-card"
          >
            Back to Home
          </a>
        </div>
      </div>
    </div>
  </section>
</Shop>
