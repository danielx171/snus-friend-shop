---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import FlavorQuizIsland from '@/components/react/FlavorQuizIsland';
import { getCollection } from 'astro:content';
import { tenant } from '@/config/tenant';

const allProducts = await getCollection('products');

const quizProducts = allProducts.map((p) => ({
  slug: p.data.slug,
  name: p.data.name,
  brand: p.data.brand,
  brandSlug: p.data.brandSlug,
  imageUrl: p.data.imageUrl,
  prices: p.data.prices,
  stock: p.data.stock,
  flavorKey: p.data.flavorKey,
  strengthKey: p.data.strengthKey,
  ratings: p.data.ratings,
  nicotineContent: p.data.nicotineContent,
}));
---

<Shop
  title={`Flavour Quiz | ${tenant.name}`}
  description="Take our flavour quiz to discover your perfect nicotine pouch. Answer a few questions and get personalised recommendations from 700+ products."
  canonical="/flavor-quiz"
>
  <section class="bg-background text-foreground">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <Breadcrumb items={[{ label: 'Flavour Quiz' }]} />

      <div class="text-center mb-4">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 border border-primary/20">
          <svg class="h-8 w-8 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Flavour Quiz</h1>
        <p class="text-muted-foreground mt-2">Find your perfect nicotine pouch in under a minute.</p>
      </div>

      <FlavorQuizIsland client:load products={quizProducts} />
    </div>
  </section>
</Shop>
