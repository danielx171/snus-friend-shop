---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Contact Us — Support & Help | ${tenant.name}`}
  description={`Get in touch with ${tenant.name}. Questions about orders, products, or shipping? We typically reply within a few hours.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Contact' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-4">Contact Us</h1>
      <p class="text-lg text-muted-foreground mb-10 leading-relaxed">
        Have a question about your order, a product, or anything else? We are here to help
        and typically reply within a few hours during business days.
      </p>

      <div class="grid gap-8 md:grid-cols-2 mb-12" data-support-email={tenant.supportEmail}>
        <!-- Email -->
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h2 class="text-lg font-semibold mb-2">Email</h2>
          <p class="text-sm text-muted-foreground mb-3">
            The fastest way to reach us. Include your order number if your question is
            about an existing order.
          </p>
          <a
            href={`mailto:${tenant.supportEmail}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
          >
            {tenant.supportEmail}
          </a>
        </div>

        <!-- Response time -->
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h2 class="text-lg font-semibold mb-2">Response Time</h2>
          <p class="text-sm text-muted-foreground">
            We aim to respond to all enquiries within <strong class="text-foreground">4 hours</strong> during
            business hours (Mon-Fri, 09:00-17:00 CET). Emails received outside business
            hours are answered the next business day.
          </p>
        </div>
      </div>

      <!-- Contact form -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 md:p-8">
        <h2 class="text-2xl font-semibold mb-6">Send Us a Message</h2>

        <form
          class="space-y-5"
          data-contact-form
          data-fn-url={`${import.meta.env.VITE_SUPABASE_URL ?? import.meta.env.PUBLIC_SUPABASE_URL ?? ''}functions/v1/contact-form`}
          data-api-key={import.meta.env.VITE_SUPABASE_PUBLISHABLE_KEY ?? import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}
        >
          <div>
            <label for="contact-name" class="block text-sm font-medium mb-1.5">Name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-medium mb-1.5">Email</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="contact-subject" class="block text-sm font-medium mb-1.5">Subject</label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
            >
              <option value="" disabled selected>Select a topic</option>
              <option value="order">Order enquiry</option>
              <option value="product">Product question</option>
              <option value="shipping">Shipping &amp; delivery</option>
              <option value="returns">Returns &amp; refunds</option>
              <option value="account">Account &amp; rewards</option>
              <option value="other">Something else</option>
            </select>
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-medium mb-1.5">Message</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              maxlength="5000"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 resize-y"
              placeholder="How can we help?"
            ></textarea>
          </div>

          <!-- Honeypot field — hidden from real users, bots will fill it -->
          <div class="absolute opacity-0 -z-10" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div id="contact-status" role="alert" aria-live="assertive" class="hidden rounded-lg px-4 py-3 text-sm"></div>

          <button
            type="submit"
            id="contact-submit-btn"
            class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Message
          </button>

          <p class="text-xs text-muted-foreground">
            By submitting this form you agree to our
            <a href="/privacy" class="underline hover:text-foreground">Privacy Policy</a>.
          </p>
        </form>
      </div>
    </div>
  </section>
</Shop>

<script is:inline>
(function() {
  function initContactForm() {
    var form = document.querySelector('[data-contact-form]');
    if (!form || form.hasAttribute('data-initialized')) return;
    form.setAttribute('data-initialized', 'true');
    var btn = document.getElementById('contact-submit-btn');
    var status = document.getElementById('contact-status');
    var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    // Read edge function URL and API key from data attributes (set at build time)
    var functionUrl = form.getAttribute('data-fn-url') || '';
    var apiKey = form.getAttribute('data-api-key') || '';

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var fd = new FormData(form);
      var name = (fd.get('name') || '').toString().trim();
      var email = (fd.get('email') || '').toString().trim();
      var subject = (fd.get('subject') || '').toString();
      var message = (fd.get('message') || '').toString().trim();
      var website = (fd.get('website') || '').toString().trim();

      if (!name || !email || !subject || !message) {
        showStatus('Please fill in all fields.', true);
        return;
      }
      if (!emailRe.test(email)) {
        showStatus('Please enter a valid email address.', true);
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Sending\u2026';
      hideStatus();

      // If edge function URL not available, fall back to mailto
      if (!functionUrl) {
        fallbackMailto(name, email, subject, message);
        return;
      }

      fetch(functionUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': apiKey
        },
        body: JSON.stringify({ name: name, email: email, subject: subject, message: message, website: website })
      })
      .then(function(res) {
        return res.json().then(function(body) {
          return { ok: res.ok, status: res.status, body: body };
        });
      })
      .then(function(result) {
        if (result.ok && result.body.success) {
          showStatus('Message sent! We will get back to you within 4 hours during business days.', false);
          form.reset();
        } else if (result.status === 429) {
          showStatus(result.body.message || 'Too many submissions. Please wait a moment and try again.', true);
        } else {
          showStatus(result.body.message || 'Something went wrong. Please try again or email us directly.', true);
        }
        btn.disabled = false;
        btn.textContent = 'Send Message';
      })
      .catch(function() {
        showStatus('Network error. Please check your connection and try again.', true);
        btn.disabled = false;
        btn.textContent = 'Send Message';
      });
    });

    function fallbackMailto(name, email, subject, message) {
      var supportEmail = document.querySelector('[data-support-email]');
      var emailAddr = supportEmail ? supportEmail.getAttribute('data-support-email') : 'support@snusfriends.com';
      var mailtoBody = 'Name: ' + name + '\nSubject: ' + subject + '\n\n' + message;
      var mailto = 'mailto:' + emailAddr + '?subject=' + encodeURIComponent(subject + ' \u2014 ' + name) + '&body=' + encodeURIComponent(mailtoBody);
      window.location.href = mailto;
      setTimeout(function() {
        showStatus('Your email client should open shortly. If it does not, email us directly at ' + emailAddr + '.', false);
        btn.disabled = false;
        btn.textContent = 'Send Message';
      }, 500);
    }

    function showStatus(text, isError) {
      status.textContent = text;
      status.className = 'rounded-lg px-4 py-3 text-sm ' + (isError ? 'bg-destructive/10 text-destructive border border-destructive/20' : 'bg-primary/10 text-primary border border-primary/20');
    }

    function hideStatus() {
      status.textContent = '';
      status.className = 'hidden rounded-lg px-4 py-3 text-sm';
    }
  }

  // Support Astro View Transitions
  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
})();
</script>
