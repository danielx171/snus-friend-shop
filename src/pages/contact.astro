---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import { tenant } from '@/config/tenant';
---

<Shop
  title={`Contact Us | ${tenant.name}`}
  description={`Get in touch with ${tenant.name}. Questions about orders, products, or shipping? We typically reply within a few hours.`}
>
  <section class="bg-background text-foreground">
    <div class="max-w-3xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Contact' }]} />

      <h1 class="text-4xl font-bold tracking-tight mb-4">Contact Us</h1>
      <p class="text-lg text-muted-foreground mb-10 leading-relaxed">
        Have a question about your order, a product, or anything else? We are here to help
        and typically reply within a few hours during business days.
      </p>

      <div class="grid gap-8 md:grid-cols-2 mb-12">
        <!-- Email -->
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h2 class="text-lg font-semibold mb-2">Email</h2>
          <p class="text-sm text-muted-foreground mb-3">
            The fastest way to reach us. Include your order number if your question is
            about an existing order.
          </p>
          <a
            href={`mailto:${tenant.supportEmail}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
          >
            {tenant.supportEmail}
          </a>
        </div>

        <!-- Response time -->
        <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
          <h2 class="text-lg font-semibold mb-2">Response Time</h2>
          <p class="text-sm text-muted-foreground">
            We aim to respond to all enquiries within <strong class="text-foreground">4 hours</strong> during
            business hours (Mon-Fri, 09:00-17:00 CET). Emails received outside business
            hours are answered the next business day.
          </p>
        </div>
      </div>

      <!-- Contact form -->
      <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6 md:p-8">
        <h2 class="text-2xl font-semibold mb-6">Send Us a Message</h2>

        <form class="space-y-5" data-contact-form>
          <div>
            <label for="contact-name" class="block text-sm font-medium mb-1.5">Name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-medium mb-1.5">Email</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="contact-subject" class="block text-sm font-medium mb-1.5">Subject</label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
            >
              <option value="" disabled selected>Select a topic</option>
              <option value="order">Order enquiry</option>
              <option value="product">Product question</option>
              <option value="shipping">Shipping &amp; delivery</option>
              <option value="returns">Returns &amp; refunds</option>
              <option value="account">Account &amp; rewards</option>
              <option value="other">Something else</option>
            </select>
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-medium mb-1.5">Message</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 resize-y"
              placeholder="How can we help?"
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50"
          >
            Send Message
          </button>

          <p class="text-xs text-muted-foreground">
            By submitting this form you agree to our
            <a href="/privacy-policy" class="underline hover:text-foreground">Privacy Policy</a>.
          </p>
        </form>
      </div>
    </div>
  </section>
</Shop>
