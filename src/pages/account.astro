---
export const prerender = false;

import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import ProfileCardIsland from '@/components/react/ProfileCardIsland';
import AvatarSelectorIsland from '@/components/react/AvatarSelectorIsland';
import AchievementGridIsland from '@/components/react/AchievementGridIsland';
import { actions } from 'astro:actions';
import { tenant } from '@/config/tenant';

// Auth check
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login?redirect=/account');
}

const supabase = Astro.locals.supabase;

// Tab selection via query param (default: orders)
const tab = Astro.url.searchParams.get('tab') || 'orders';

// Fetch orders
const { data: orders } = await supabase
  .from('orders')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(20);

// Fetch points balance
const { data: pointsBalance } = await supabase
  .from('points_balances')
  .select('*')
  .eq('user_id', user.id)
  .single();

// Fetch review count for profile stats
const { count: reviewsCount } = await supabase
  .from('product_reviews')
  .select('id', { count: 'exact', head: true })
  .eq('user_id', user.id);

// User metadata
const fullName = user.user_metadata?.full_name || '';
const phone = user.user_metadata?.phone || '';

// Check action results
const profileResult = Astro.getActionResult(actions.account.updateProfile);
const passwordResult = Astro.getActionResult(actions.account.changePassword);
const logoutResult = Astro.getActionResult(actions.auth.logout);

if (logoutResult && !logoutResult.error) {
  return Astro.redirect('/');
}

// Status badge color helper
function statusColor(status: string): string {
  switch (status) {
    case 'paid': case 'completed': return 'bg-primary/20 text-primary';
    case 'shipped': return 'bg-accent/20 text-accent-foreground';
    case 'pending': return 'bg-muted text-muted-foreground';
    case 'cancelled': case 'refunded': return 'bg-destructive/20 text-destructive';
    default: return 'bg-muted text-muted-foreground';
  }
}

// Tier calculation
const balance = pointsBalance?.balance ?? 0;
const lifetime = pointsBalance?.lifetime_earned ?? 0;
function getTier(pts: number) {
  if (pts >= 5000) return { name: 'Diamond', next: null, threshold: 5000 };
  if (pts >= 2000) return { name: 'Gold', next: 'Diamond', threshold: 5000 };
  if (pts >= 500) return { name: 'Silver', next: 'Gold', threshold: 2000 };
  return { name: 'Bronze', next: 'Silver', threshold: 500 };
}
const tier = getTier(lifetime);
const progress = tier.next ? Math.min(100, Math.round((lifetime / tier.threshold) * 100)) : 100;
---

<Shop
  title={`Account | ${tenant.name}`}
  description="Manage your account, orders, and membership."
  noindex={true}
>
  <section class="bg-background text-foreground">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <Breadcrumb items={[{ label: 'Account' }]} />

      <h1 class="text-3xl font-bold tracking-tight mb-2">My Account</h1>
      <p class="text-muted-foreground mb-6">Welcome back, {fullName || user.email}</p>

      <!-- Gamification Profile Card -->
      <div class="mb-8">
        <ProfileCardIsland
          client:visible
          ordersCount={orders?.length ?? 0}
          reviewsCount={reviewsCount ?? 0}
          snusPoints={balance}
        />
      </div>

      <!-- Avatar Selector -->
      <div class="mb-8 rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
        <AvatarSelectorIsland client:visible />
      </div>

      <!-- Tab Navigation -->
      <div class="flex gap-1 border-b border-border mb-8">
        <a
          href="/account?tab=orders"
          class:list={[
            'px-4 py-2.5 text-sm font-medium rounded-t-lg transition',
            tab === 'orders'
              ? 'bg-card/60 text-foreground border border-border border-b-transparent -mb-px'
              : 'text-muted-foreground hover:text-foreground',
          ]}
        >
          Orders
        </a>
        <a
          href="/account?tab=settings"
          class:list={[
            'px-4 py-2.5 text-sm font-medium rounded-t-lg transition',
            tab === 'settings'
              ? 'bg-card/60 text-foreground border border-border border-b-transparent -mb-px'
              : 'text-muted-foreground hover:text-foreground',
          ]}
        >
          Settings
        </a>
        <a
          href="/account?tab=membership"
          class:list={[
            'px-4 py-2.5 text-sm font-medium rounded-t-lg transition',
            tab === 'membership'
              ? 'bg-card/60 text-foreground border border-border border-b-transparent -mb-px'
              : 'text-muted-foreground hover:text-foreground',
          ]}
        >
          Membership
        </a>
      </div>

      <!-- Orders Tab -->
      {tab === 'orders' && (
        <div class="space-y-4">
          {(!orders || orders.length === 0) ? (
            <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-8 text-center">
              <p class="text-muted-foreground mb-4">You have not placed any orders yet.</p>
              <a href="/products" class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition">
                Browse Cans
              </a>
            </div>
          ) : (
            orders.map((order: any) => (
              <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-5">
                <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                  <div>
                    <span class="text-sm text-muted-foreground">Order</span>
                    <span class="ml-1.5 font-mono text-sm font-medium">
                      #{order.nyehandel_order_id || order.id.slice(0, 8)}
                    </span>
                  </div>
                  <span class:list={['px-2.5 py-0.5 rounded-full text-xs font-medium', statusColor(order.checkout_status)]}>
                    {order.checkout_status}
                  </span>
                </div>
                <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                  <span>{new Date(order.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                  <span>{order.currency} {order.total_price.toFixed(2)}</span>
                  {order.tracking_url && (
                    <a href={order.tracking_url} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
                      Track shipment
                    </a>
                  )}
                </div>
              </div>
            ))
          )}
        </div>
      )}

      <!-- Settings Tab -->
      {tab === 'settings' && (
        <div class="space-y-8">
          {/* Profile Form */}
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <h2 class="text-lg font-semibold mb-4">Profile</h2>

            {profileResult?.error && (
              <div class="rounded-lg bg-destructive/10 border border-destructive/30 p-3 mb-4 text-sm text-destructive">
                {profileResult.error.message}
              </div>
            )}
            {profileResult?.data?.success && (
              <div class="rounded-lg bg-emerald-500/10 border border-emerald-500/30 p-3 mb-4 text-sm text-emerald-400">
                Profile updated successfully.
              </div>
            )}

            <form method="POST" action={actions.account.updateProfile} class="space-y-4">
              <div>
                <label for="email" class="block text-sm font-medium text-muted-foreground mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  value={user.email}
                  disabled
                  class="w-full rounded-lg border border-border bg-muted/30 px-3 py-2 text-sm text-muted-foreground cursor-not-allowed"
                />
              </div>
              <div>
                <label for="fullName" class="block text-sm font-medium text-muted-foreground mb-1.5">Full Name</label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  value={fullName}
                  required
                  class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-muted-foreground mb-1.5">Phone (optional)</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  value={phone}
                  class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                />
              </div>
              <button
                type="submit"
                class="rounded-lg bg-primary px-5 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition"
              >
                Save Changes
              </button>
            </form>
          </div>

          {/* Change Password Form */}
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <h2 class="text-lg font-semibold mb-4">Change Password</h2>

            {passwordResult?.error && (
              <div class="rounded-lg bg-destructive/10 border border-destructive/30 p-3 mb-4 text-sm text-destructive">
                {passwordResult.error.message}
              </div>
            )}
            {passwordResult?.data?.success && (
              <div class="rounded-lg bg-emerald-500/10 border border-emerald-500/30 p-3 mb-4 text-sm text-emerald-400">
                Password changed successfully.
              </div>
            )}

            <form method="POST" action={actions.account.changePassword} class="space-y-4" id="change-password-form">
              <div>
                <label for="newPassword" class="block text-sm font-medium text-muted-foreground mb-1.5">New Password</label>
                <input
                  type="password"
                  id="newPassword"
                  name="newPassword"
                  required
                  minlength="8"
                  class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                />
              </div>
              <div>
                <label for="confirmPassword" class="block text-sm font-medium text-muted-foreground mb-1.5">Confirm Password</label>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                  minlength="8"
                  class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                />
                <p id="pw-mismatch" class="text-sm text-destructive mt-1 hidden">Passwords do not match</p>
              </div>
              <button
                type="submit"
                class="rounded-lg bg-primary px-5 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition"
              >
                Change Password
              </button>
            </form>
          </div>

          {/* Logout */}
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <h2 class="text-lg font-semibold mb-4">Sign Out</h2>
            <p class="text-sm text-muted-foreground mb-4">Sign out of your account on this device.</p>
            <form method="POST" action={actions.auth.logout}>
              <button
                type="submit"
                class="rounded-lg border border-border px-5 py-2 text-sm font-medium text-foreground hover:bg-muted/50 transition"
              >
                Sign Out
              </button>
            </form>
          </div>
        </div>
      )}

      <!-- Membership Tab -->
      {tab === 'membership' && (
        <div class="space-y-6">
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-lg font-semibold">{tenant.loyaltyProgramName}</h2>
              <span class="px-3 py-1 rounded-full bg-primary/20 text-primary text-sm font-medium">
                {tier.name}
              </span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <div class="rounded-lg bg-background/50 p-4 text-center">
                <p class="text-2xl font-bold text-primary">{balance.toLocaleString()}</p>
                <p class="text-xs text-muted-foreground mt-1">Available Points</p>
              </div>
              <div class="rounded-lg bg-background/50 p-4 text-center">
                <p class="text-2xl font-bold">{lifetime.toLocaleString()}</p>
                <p class="text-xs text-muted-foreground mt-1">Lifetime Earned</p>
              </div>
            </div>

            {tier.next && (
              <div>
                <div class="flex justify-between text-xs text-muted-foreground mb-1.5">
                  <span>{tier.name}</span>
                  <span>{tier.next} ({tier.threshold.toLocaleString()} pts)</span>
                </div>
                <div class="w-full h-2 bg-background/50 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-primary rounded-full transition-all"
                    style={`width: ${progress}%`}
                  />
                </div>
                <p class="text-xs text-muted-foreground mt-2">
                  {(tier.threshold - lifetime).toLocaleString()} points to {tier.next}
                </p>
              </div>
            )}

            {!tier.next && (
              <p class="text-sm text-primary">
                You have reached the highest tier. Thank you for your loyalty!
              </p>
            )}
          </div>

          <!-- Achievements -->
          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <AchievementGridIsland client:visible />
          </div>

          <div class="rounded-xl border border-border bg-card/60 backdrop-blur-sm p-6">
            <h3 class="text-sm font-semibold mb-3">How to Earn Points</h3>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                Place orders — earn 1 point per EUR spent
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                Write product reviews — earn 50 points each
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                Complete quests and challenges for bonus points
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                Refer a friend — both earn 200 points
              </li>
            </ul>
          </div>
        </div>
      )}
    </div>
  </section>
</Shop>

<!-- Progressive enhancement: client-side password match check -->
<script>
  const form = document.getElementById('change-password-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      const pw = (document.getElementById('newPassword') as HTMLInputElement)?.value;
      const cpw = (document.getElementById('confirmPassword') as HTMLInputElement)?.value;
      const msg = document.getElementById('pw-mismatch');
      if (pw !== cpw) {
        e.preventDefault();
        msg?.classList.remove('hidden');
      } else {
        msg?.classList.add('hidden');
      }
    });
  }
</script>
