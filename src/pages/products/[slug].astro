---
export const prerender = true;
import { Image } from 'astro:assets';
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import ProductCard from '@/components/astro/ProductCard.astro';
import AddToCartButton from '@/components/react/AddToCartButton';
import StickyAddToCart from '@/components/react/StickyAddToCart';
import ProductReviewsIsland from '@/components/react/ProductReviewsIsland';
import { getCollection } from 'astro:content';
import { brandColors, defaultBrandColor } from '@/data/brand-colors';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map((product) => ({
    params: { slug: product.id },
    props: {
      product,
      relatedProducts: allProducts
        .filter((rp) => rp.data.brandSlug === product.data.brandSlug && rp.id !== product.id)
        .slice(0, 4),
    },
  }));
}

const { product, relatedProducts } = Astro.props;
const p = product.data;
const bColor = brandColors[p.brandSlug] ?? defaultBrandColor;

// Calculate savings for pack pricing
const singlePrice = p.prices.pack1;
const packSavings: Record<string, number> = {};
for (const [key, price] of Object.entries(p.prices)) {
  if (key === 'pack1' || typeof price !== 'number' || price <= 0) continue;
  const qty = parseInt(key.replace('pack', ''));
  if (!qty || qty <= 1) continue;
  const perCan = price / qty;
  const saving = Math.round((1 - perCan / singlePrice) * 100);
  if (saving > 0) packSavings[key] = saving;
}

const strengthMap: Record<string, number> = {
  normal: 2,
  strong: 3,
  'extra-strong': 4,
  'super-strong': 5,
};
const strengthLevel = strengthMap[p.strengthKey] ?? 2;

const strengthLabels: Record<string, string> = {
  normal: 'Normal',
  strong: 'Strong',
  'extra-strong': 'Extra Strong',
  'super-strong': 'Super Strong',
};
const strengthLabel = strengthLabels[p.strengthKey] ?? 'Normal';

const flavorLabels: Record<string, string> = {
  mint: 'Mint',
  berry: 'Berry',
  citrus: 'Citrus',
  fruit: 'Fruit',
  coffee: 'Coffee',
  cola: 'Cola',
  menthol: 'Menthol',
  wintergreen: 'Wintergreen',
  tropical: 'Tropical',
  ice: 'Ice',
  original: 'Original',
};
const flavorLabel = flavorLabels[p.flavorKey] ?? p.flavorKey;

// Theme-aware flavor colors — no hardcoded Tailwind palette colors
const flavorColor = 'bg-primary/10 text-primary border-primary/20';

// Generate an accurate fallback description from real product attributes
const generatedDescription = `${p.name} by ${p.brand}. ${p.nicotineContent} mg/pouch nicotine pouches in ${p.formatKey || 'slim'} format with ${flavorLabel.toLowerCase()} flavour. ${strengthLabel} strength. ${p.portionsPerCan} portions per can.`;

// Detect bad template descriptions: if the stored description mentions a different
// format or contains "cool mint" for a non-cool-mint product, use the generated one instead
const storedDesc = (p.description || '').toLowerCase();
const nameLower = p.name.toLowerCase();
const isBadDescription = !p.description
  || (storedDesc.includes('cool mint') && !nameLower.includes('cool mint'))
  || (storedDesc.includes('slim format') && p.formatKey !== 'slim')
  || (storedDesc.includes('mini format') && p.formatKey !== 'mini')
  || storedDesc.includes('shop snusfriends.com');

const description = isBadDescription ? generatedDescription : p.description;
const metaDescription = description.length > 160 ? description.slice(0, 157) + '...' : description;

const packTiers = [
  { key: 'pack1', label: '1 can', qty: 1 },
  { key: 'pack3', label: '3 cans', qty: 3 },
  { key: 'pack5', label: '5 cans', qty: 5 },
  { key: 'pack10', label: '10 cans', qty: 10 },
];

const inStock = p.stock > 0;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: p.name,
  image: p.imageUrl || undefined,
  description: description,
  brand: {
    '@type': 'Brand',
    name: p.brand,
  },
  sku: p.slug,
  ...(p.updatedAt && { dateModified: new Date(p.updatedAt).toISOString() }),
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: Math.min(...Object.values(p.prices).filter((v): v is number => typeof v === 'number' && v > 0)),
    highPrice: Math.max(...Object.values(p.prices).filter((v): v is number => typeof v === 'number' && v > 0)),
    offerCount: Object.keys(p.prices).length,
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
  url: `https://snusfriends.com/products/${p.slug}`,
  ...(p.ratings > 0 && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: p.ratings.toFixed(1),
      bestRating: '5',
      ratingCount: '1',
    },
  }),
};
---

<Shop
  title={`${p.name} | SnusFriend`}
  description={metaDescription}
  ogType="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="mx-auto max-w-6xl px-4 py-8 sm:py-12">
    <Breadcrumb items={[
      { label: 'Products', href: '/products' },
      { label: p.name },
    ]} />

    <!-- Two-column PDP layout -->
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">

      <!-- Left: Product Image -->
      <div class="group/img relative">
        <div class="overflow-hidden rounded-2xl border border-border cursor-zoom-in" style={`background: linear-gradient(135deg, ${bColor}15, ${bColor}08);`} id="pdp-image-container">
          <div class="relative aspect-square w-full">
            {p.imageUrl ? (
              <Image
                src={p.imageUrl}
                alt={p.name}
                width={600}
                height={600}
                loading="eager"
                format="webp"
                quality={85}
                class="h-full w-full object-contain p-8 transition-transform duration-200"
                id="pdp-image"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-muted-foreground/40">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
            )}
          </div>
        </div>

        {/* Badges overlay */}
        {p.badgeKeys.length > 0 && (
          <div class="absolute left-4 top-4 flex flex-col gap-1.5">
            {p.badgeKeys.map((badge: string) => (
              <span class="rounded-md bg-primary px-2.5 py-1 text-xs font-semibold text-primary-foreground shadow-lg shadow-primary/20">
                {badge.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}
              </span>
            ))}
          </div>
        )}

        {/* Stock overlay */}
        {!inStock && (
          <div class="absolute inset-0 flex items-center justify-center rounded-2xl bg-background/60 backdrop-blur-sm">
            <span class="rounded-lg bg-destructive/90 px-4 py-2 text-sm font-semibold text-destructive-foreground">
              Out of Stock
            </span>
          </div>
        )}
      </div>

      <!-- Right: Product Info -->
      <div class="flex flex-col">
        {/* Brand */}
        <a
          href={`/brands/${p.brandSlug}`}
          class="mb-2 text-sm font-medium uppercase tracking-widest text-primary hover:underline"
        >
          {p.brand}
        </a>

        {/* Product Name */}
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {p.name}
        </h1>

        {/* Star Rating */}
        {p.ratings > 0 && (
          <div class="mb-4 flex items-center gap-2">
            <div class="flex items-center gap-0.5" role="img" aria-label={`Rating: ${p.ratings.toFixed(1)} out of 5 stars`}>
              {Array.from({ length: 5 }, (_, i) => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class={`h-4 w-4 ${i < Math.round(p.ratings) ? 'fill-primary text-primary' : 'fill-muted text-muted'}`}
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <span class="text-sm text-muted-foreground">{p.ratings.toFixed(1)}</span>
          </div>
        )}

        {/* Flavor Badge + Strength Indicator */}
        <div class="mb-6 flex flex-wrap items-center gap-3">
          <span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium ${flavorColor}`}>
            {flavorLabel}
          </span>

          <div class="flex items-center gap-2">
            <div class="flex items-center gap-0.5" role="img" aria-label={`Strength ${strengthLevel} of 5`}>
              {Array.from({ length: 5 }, (_, i) => (
                <span
                  class={`inline-block h-2 w-2 rounded-full ${i < strengthLevel ? 'bg-primary' : 'bg-muted-foreground/25'}`}
                />
              ))}
            </div>
            <span class="text-xs text-muted-foreground">{strengthLabel}</span>
          </div>
        </div>

        {/* Quick Specs */}
        <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-lg border border-border bg-card/40 p-3 text-center backdrop-blur">
            <p class="text-xs text-muted-foreground">Nicotine</p>
            <p class="text-sm font-semibold text-foreground">{p.nicotineContent} mg/pouch</p>
          </div>
          <div class="rounded-lg border border-border bg-card/40 p-3 text-center backdrop-blur">
            <p class="text-xs text-muted-foreground">Portions</p>
            <p class="text-sm font-semibold text-foreground">{p.portionsPerCan}/can</p>
          </div>
          <div class="rounded-lg border border-border bg-card/40 p-3 text-center backdrop-blur">
            <p class="text-xs text-muted-foreground">Format</p>
            <p class="text-sm font-semibold text-foreground capitalize">{p.formatKey}</p>
          </div>
          <div class="rounded-lg border border-primary/20 bg-primary/5 p-3 text-center backdrop-blur">
            <p class="text-xs text-muted-foreground">Price/Pouch</p>
            <p class="text-sm font-semibold text-primary">&euro;{(singlePrice / (p.portionsPerCan || 20)).toFixed(2)}</p>
          </div>
        </div>

        {/* Stock Status */}
        <div class="mb-6 flex items-center gap-2">
          {inStock ? (
            <>
              <span class="inline-block h-2 w-2 rounded-full bg-primary" />
              <span class="text-sm text-primary">In Stock</span>
            </>
          ) : (
            <>
              <span class="inline-block h-2 w-2 rounded-full bg-destructive" />
              <span class="text-sm text-destructive">Out of Stock</span>
            </>
          )}
        </div>

        {/* Add to Cart — React island */}
        <div class="mb-8" data-add-to-cart-main>
          <AddToCartButton
            client:visible
            product={{
              slug: p.slug,
              name: p.name,
              brand: p.brand,
              imageUrl: p.imageUrl,
              prices: p.prices,
              stock: p.stock ?? 0,
              flavorKey: p.flavorKey,
              strengthKey: p.strengthKey,
              formatKey: p.formatKey,
              nicotineContent: p.nicotineContent,
              portionsPerCan: p.portionsPerCan,
            }}
          />
        </div>

        {/* Description */}
        {description && (
          <div class="rounded-xl border border-border bg-card/30 p-5 backdrop-blur">
            <h2 class="mb-2 text-sm font-semibold text-foreground">Description</h2>
            <p class="text-sm leading-relaxed text-muted-foreground">
              {description}
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Internal links to categories -->
    <nav class="mt-10 flex flex-wrap gap-3" aria-label="Related categories">
      {p.flavorKey && flavorLabels[p.flavorKey] && (
        <a
          href={`/products/flavor/${p.flavorKey}`}
          class="rounded-lg border border-border bg-card/50 px-4 py-2 text-sm font-medium text-foreground transition hover:border-primary/40 hover:bg-primary/5"
        >
          More {flavorLabel} Pouches
        </a>
      )}
      {p.strengthKey && strengthLabels[p.strengthKey] && (
        <a
          href={`/products/strength/${p.strengthKey}`}
          class="rounded-lg border border-border bg-card/50 px-4 py-2 text-sm font-medium text-foreground transition hover:border-primary/40 hover:bg-primary/5"
        >
          More {strengthLabel} Pouches
        </a>
      )}
      <a
        href={`/brands/${p.brandSlug}`}
        class="rounded-lg border border-border bg-card/50 px-4 py-2 text-sm font-medium text-foreground transition hover:border-primary/40 hover:bg-primary/5"
      >
        All {p.brand} Cans
      </a>
      <a
        href={`/compare?products=${product.id}`}
        class="rounded-lg border border-primary/30 bg-primary/5 px-4 py-2 text-sm font-medium text-primary transition hover:bg-primary/10"
      >
        Compare
      </a>
    </nav>

    <!-- Customer Reviews -->
    <section class="mt-12">
      <ProductReviewsIsland client:visible productId={product.id} />
    </section>

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-xl font-bold text-foreground">More from {p.brand}</h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {relatedProducts.map((rp: any) => (
            <ProductCard
              slug={rp.id}
              name={rp.data.name}
              brand={rp.data.brand}
              brandSlug={rp.data.brandSlug}
              imageUrl={rp.data.imageUrl}
              prices={rp.data.prices}
              stock={rp.data.stock}
              nicotineContent={rp.data.nicotineContent}
              strengthKey={rp.data.strengthKey}
              flavorKey={rp.data.flavorKey}
              ratings={rp.data.ratings}
              badgeKeys={rp.data.badgeKeys}
            />
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- Record product view for browsing history -->
  <script is:inline define:vars={{ viewData: { slug: product.id, brand: p.brand, flavorKey: p.flavorKey, strengthKey: p.strengthKey } }}>
    document.addEventListener('astro:page-load', () => {
      try {
        const key = 'snusfriend_history';
        const raw = localStorage.getItem(key);
        const history = raw ? JSON.parse(raw) : [];
        const filtered = history.filter(h => h.slug !== viewData.slug);
        const updated = [{ ...viewData, viewedAt: new Date().toISOString() }, ...filtered].slice(0, 30);
        localStorage.setItem(key, JSON.stringify(updated));
      } catch { /* ignore */ }
    }, { once: true });
  </script>

  <!-- Sticky Add to Cart bar (mobile only) -->
  <StickyAddToCart
    client:idle
    productId={product.id}
    name={p.name}
    brand={p.brand}
    price={p.prices.pack1}
    imageUrl={p.imageUrl}
    flavorKey={p.flavorKey}
    strengthKey={p.strengthKey}
    nicotineContent={p.nicotineContent}
    ratings={p.ratings}
    badgeKeys={p.badgeKeys}
    prices={p.prices}
    stock={p.stock}
  />

  <!-- Image zoom script -->
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const container = document.getElementById('pdp-image-container');
      const img = document.getElementById('pdp-image');
      if (!container || !img) return;

      container.addEventListener('mousemove', (e) => {
        const rect = container.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        img.style.transformOrigin = x + '% ' + y + '%';
        img.style.transform = 'scale(2)';
      });

      container.addEventListener('mouseleave', () => {
        img.style.transform = 'scale(1)';
      });
    });
  </script>
</Shop>
