---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import FilterableProductGrid from '@/components/react/FilterableProductGrid';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const serialized = JSON.stringify(products.map(p => ({ ...p.data, slug: p.id })));
---

<Shop
  title="Shop All Nicotine Pouches | SnusFriend"
  description="Browse our full collection of 700+ premium nicotine pouches from 91 top brands. Filter by strength, flavour, brand and format. Free EU shipping on qualifying orders."
  canonical="/products"
>
  <Breadcrumb items={[{ label: 'Products' }]} />

  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Shop All Nicotine Pouches
      </h1>
      <p class="mt-2 max-w-3xl text-base text-muted-foreground leading-relaxed">
        Browse our full collection of premium nicotine pouches. Use the filters to narrow by
        <a href="/products/flavor/mint" class="underline hover:text-foreground">flavour</a>,
        <a href="/products/strength/strong" class="underline hover:text-foreground">strength</a>,
        brand, or format — or explore our curated
        <a href="/nicotine-pouches" class="underline hover:text-foreground">nicotine pouches guide</a> for
        recommendations.
      </p>
    </div>

    <FilterableProductGrid client:idle productsJson={serialized} />
  </div>
</Shop>
