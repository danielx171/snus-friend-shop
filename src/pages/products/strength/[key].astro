---
export const prerender = true;
import Shop from '@/layouts/Shop.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
import FilterableProductGrid from '@/components/react/FilterableProductGrid';
import { getCollection } from 'astro:content';
import { ensureProductsJson } from '@/lib/product-json';

const STRENGTH_META: Record<string, { label: string; range: string; h1: string; desc: string; intro: string }> = {
  'light': {
    label: 'Light',
    range: '1-4mg',
    h1: 'Light Nicotine Pouches (1\u20134mg)',
    desc: 'Shop light nicotine pouches (1-4mg) \u2014 perfect for beginners. Gentle options from ZYN, VELO, HELWIT, ACE. Free EU delivery over \u20ac29.',
    intro: 'Light nicotine pouches delivering 1 to 4mg per pouch are the natural starting point for newcomers and the preferred daily option for users who enjoy the pouch experience without strong nicotine intensity. At this strength, you get a gentle, barely-there nicotine sensation that lets you focus on flavour and the physical comfort of the pouch. ZYN Mini at 1.5mg is one of the lightest options available, while HELWIT (3.5mg) and ACE (3.0mg) offer slightly more presence while staying firmly in beginner territory. KLAR uses its bioceramic technology to deliver even gentle strengths efficiently, and Kelly White keeps its entire range within this bracket. Light pouches are also popular with experienced users who want to reduce their intake without giving up the habit entirely.',
  },
  'normal': {
    label: 'Normal',
    range: '4-6mg',
    h1: 'Normal Strength Nicotine Pouches (4\u20136mg)',
    desc: 'Shop normal strength nicotine pouches (4-6mg) \u2014 the most popular everyday strength. ZYN, VELO, Skruf and more. Free EU delivery over \u20ac29.',
    intro: 'Normal strength nicotine pouches at 4 to 6mg per pouch represent the sweet spot for most regular users. This is where the majority of daily-use pouches from ZYN, VELO, Skruf, and other major brands are concentrated. At this strength, you get a clear, satisfying nicotine sensation without the intense buzz that stronger options deliver. Most users who have been through the beginner phase settle here for everyday use. Chainpop, Fix, and Apres do particularly well in this range with flavour-forward options where the taste shines through without being overwhelmed by nicotine intensity. If you use pouches throughout the day and want something that stays comfortable from morning to evening, normal strength is where most people find their balance.',
  },
  'strong': {
    label: 'Strong',
    range: '6-12mg',
    h1: 'Strong Nicotine Pouches (6\u201312mg)',
    desc: 'Shop strong nicotine pouches (6-12mg) \u2014 satisfying kick from ZYN, VELO, Loop, Skruf and 50+ brands. Free EU delivery over \u20ac29.',
    intro: 'Strong nicotine pouches at 6 to 12mg per pouch deliver a noticeable, satisfying kick that experienced users appreciate. This is the bracket where former smokers and traditional snus users typically land when switching to pouches, as it provides enough nicotine to genuinely satisfy cravings. Loop Strong, Skruf Extra Strong, VELO Strong, and ZYN Strong all have excellent options in this range. Klint and VID also sit comfortably here with flavour-forward products. The nicotine sensation is clear but not overwhelming, making these pouches viable for extended sessions of 30 minutes or more. If you have tried normal-strength pouches and find them a bit too mild, strong is the logical next step without venturing into extreme territory.',
  },
  'extra-strong': {
    label: 'Extra Strong',
    range: '12-20mg',
    h1: 'Extra Strong Nicotine Pouches (12\u201320mg)',
    desc: 'Shop extra strong nicotine pouches (12-20mg) \u2014 powerful options from White Fox, KUMA, Loop, Siberia. Free EU delivery over \u20ac29.',
    intro: 'Extra strong nicotine pouches at 12 to 20mg per pouch are built for experienced users with established tolerance who want a powerful, fast-acting nicotine hit. White Fox (12-24mg), KUMA (13.75mg), Loop Hyper Strong, and Siberia all have flagship products in this range. The nicotine sensation is immediate and pronounced, so these are not pouches you use casually throughout the day. Most users in this bracket have worked their way up from normal or strong over months. VELO Max, Klint Extra Strong, and MYNT also offer compelling options here. If you are a long-time pouch user or a heavy former smoker who finds the 6-12mg range too mild, extra strong delivers the intensity you are looking for.',
  },
  'super-strong': {
    label: 'Super Strong',
    range: '20mg+',
    h1: 'Super Strong Nicotine Pouches (20mg+)',
    desc: 'Shop super strong nicotine pouches (20mg+) \u2014 Siberia, CUBA, Rabbit, ICEBERG. Maximum strength for experienced users. Free EU delivery over \u20ac29.',
    intro: 'Super strong nicotine pouches at 20mg and above represent the extreme end of the market. Siberia (up to 49.5mg per pouch), CUBA Black (43mg), Rabbit (50mg), ICEBERG (up to 40mg), and MAGGIE (45mg) lead this category with products that deliver an intense, unmistakable nicotine punch. These pouches are exclusively for experienced users with high tolerance who have deliberately worked their way up over time. We strongly recommend against starting here or jumping to this strength from a lower bracket. The nicotine hit is fast, powerful, and can cause nausea, dizziness, or hiccups in users who are not prepared. Garant, GLICK, STNG MAX, and NOiS also have strong options at the lower end of this range for users exploring the 20-25mg bracket.',
  },
};

export async function getStaticPaths() {
  const keys = ['light', 'normal', 'strong', 'extra-strong', 'super-strong'];
  return keys.map((key) => ({ params: { key }, props: { key } }));
}

const ALL_STRENGTH_KEYS = Object.keys(STRENGTH_META);
const FLAVOR_LINKS = [
  { key: 'mint', label: 'Mint' },
  { key: 'citrus', label: 'Citrus' },
  { key: 'berry', label: 'Berry' },
  { key: 'coffee', label: 'Coffee' },
  { key: 'tobacco', label: 'Tobacco' },
  { key: 'exotic', label: 'Exotic' },
  { key: 'unflavored', label: 'Unflavored' },
];

const { key } = Astro.props;
const meta = STRENGTH_META[key as keyof typeof STRENGTH_META];
const allProducts = await getCollection('products');
const products = allProducts.filter((p) => p.data.strengthKey === key);

ensureProductsJson(allProducts);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: meta.h1,
  description: meta.desc,
  url: `https://snusfriends.com/products/strength/${key}`,
  numberOfItems: products.length,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.slice(0, 20).map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://snusfriends.com/products/${p.id}`,
      name: p.data.name,
    })),
  },
};
---

<Shop
  title={`${meta.h1} | SnusFriend`}
  description={meta.desc}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="mx-auto max-w-7xl px-4 py-8 sm:py-12">
    <Breadcrumb items={[
      { label: 'Products', href: '/products' },
      { label: meta.label },
    ]} />

    <header class="mb-8">
      <h1 class="mb-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        {meta.h1}
      </h1>
      <p class="max-w-3xl text-base leading-relaxed text-muted-foreground">
        {meta.intro}
      </p>
      <p class="mt-2 text-sm text-muted-foreground">
        Nicotine range: <strong class="text-foreground">{meta.range}</strong> &middot; {products.length} cans
      </p>
    </header>

    <h2 class="sr-only">Product Catalog</h2>
    <FilterableProductGrid
      client:idle
      productsJsonUrl="/data/products.json"
      initialFilters={JSON.stringify({ strengths: [key] })}
    />

    <!-- Cross-links to other strength categories -->
    <nav class="mt-12 border-t border-border pt-8" aria-label="Browse by strength">
      <h2 class="mb-4 text-lg font-semibold text-foreground">Browse by Strength</h2>
      <div class="flex flex-wrap gap-3">
        {ALL_STRENGTH_KEYS.map((k) => {
          const m = STRENGTH_META[k];
          const isCurrent = k === key;
          return (
            <a
              href={`/products/strength/${k}`}
              class={`rounded-lg border px-4 py-2 text-sm font-medium transition ${
                isCurrent
                  ? 'border-primary bg-primary/10 text-primary pointer-events-none'
                  : 'border-border bg-card text-foreground hover:border-primary/40 hover:bg-primary/5'
              }`}
              aria-current={isCurrent ? 'page' : undefined}
            >
              {m.label} <span class="text-xs text-muted-foreground">({m.range})</span>
            </a>
          );
        })}
      </div>
    </nav>

    <!-- Cross-links to flavor categories -->
    <nav class="mt-6 border-t border-border pt-8" aria-label="Browse by flavour">
      <h2 class="mb-4 text-lg font-semibold text-foreground">Browse by Flavour</h2>
      <div class="flex flex-wrap gap-3">
        {FLAVOR_LINKS.map((f) => (
          <a
            href={`/products/flavor/${f.key}`}
            class="rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition hover:border-primary/40 hover:bg-primary/5"
          >
            {f.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</Shop>
